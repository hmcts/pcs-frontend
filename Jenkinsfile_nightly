#!groovy

properties([
  // H allow predefined but random minute see https://en.wikipedia.org/wiki/Cron#Non-standard_characters
  pipelineTriggers([cron('H 07 * * 1-5')]),
  parameters([
    text(
      name: 'MANUAL_BUILD_REASON',
      defaultValue: 'Daily nightly schedule run',
      description: 'Why this build was triggered. For manual runs, enter a short note (e.g. verify a fix, extra browser coverage). Scheduled runs keep the default.'
    ),
    choice(
      name: 'ENVIRONMENT',
      choices: ['aat', 'preview'],
      description: 'Environment to run the test.'
    ),
    string(
      name: 'PR_NUMBER',
      defaultValue: '',
      description: 'PR number (REQUIRED if environment is preview, leave blank otherwise).'
    ),
    booleanParam(
      name: 'CHROME_TESTS',
      defaultValue: true,
      description: 'Run E2E tests in Chrome (on by default).'
    ),
    booleanParam(
      name: 'FIREFOX_TESTS',
      defaultValue: false,
      description: 'Run E2E tests in Firefox (off by default; enable when needed).'
    ),
    booleanParam(
      name: 'WEBKIT_TESTS',
      defaultValue: false,
      description: 'Run E2E tests in WebKit / desktop Safari (off by default; enable when needed).'
    ),
    booleanParam(
      name: 'EDGE_TESTS',
      defaultValue: false,
      description: 'Run E2E tests in Microsoft Edge (off by default; enable when needed).'
    ),
    booleanParam(
      name: 'MOBILE_ANDROID_TESTS',
      defaultValue: false,
      description: 'Run E2E tests on the Android (Pixel 5) profile (off by default; enable when needed).'
    ),
    booleanParam(
      name: 'MOBILE_IOS_TESTS',
      defaultValue: false,
      description: 'Run E2E tests on the iOS (iPhone 12) WebKit profile (off by default; enable when needed).'
    ),
    booleanParam(
      name: 'MOBILE_IPAD_TESTS',
      defaultValue: false,
      description: 'Run E2E tests on the iPad (iPad Pro 11) WebKit profile (off by default; enable when needed).'
    ),
    string(
      name: 'PLAYWRIGHT_SPEC',
      defaultValue: '',
      description: 'Spec file filter: each keyword must appear in the path of a *.spec.ts under src/test/ui (case-sensitive). Separate keywords with comma or semicolon. Ex.: respondToAClaim | respondToAClaim,makeAnApplication. Blank = all specs. Default: empty.'
    ),
    choice(
      name: 'PLAYWRIGHT_GREP_TAG',
      choices: ['@nightly', '@smoke', '@e2e', '@crossbrowser', '(all tests)'],
      description: 'Test title grep. (all tests) = no grep. Default: @nightly.'
    ),
    choice(
      name: 'ENABLE_ALL_PAGE_FUNCTIONAL_TESTS',
      choices: ['true', 'false'],
      description: 'Run page functional tests (content, errors, navigation). Default: true.'
    ),
    choice(
      name: 'ENABLE_AXE_AUDIT',
      choices: ['true', 'false'],
      description: 'Run axe audits during E2E. Default: true.'
    ),
  ])
])

@Library("Infrastructure")

def type = "nodejs"
def product = "pcs"
def component = "frontend"

def yarnBuilder = new uk.gov.hmcts.contino.YarnBuilder(this)

static Map secret(String secretName, String envVariable) {
  [$class     : 'AzureKeyVaultSecret',
   secretType : 'Secret',
   name       : secretName,
   envVariable: envVariable
  ]
}

def secrets = [
  'pcs-${env}': [
    secret('pcs-frontend-idam-secret', 'PCS_FRONTEND_IDAM_SECRET'),
    secret('idam-pcs-user-password', 'IDAM_PCS_USER_PASSWORD'),
    secret('pcs-solicitor-automation-uid', 'PCS_SOLICITOR_AUTOMATION_UID')
  ]
]

withNightlyPipeline(type, product, component) {
  validateInputs()
  recordOriginMasterHeadForReference()
  echo "Nightly build reason / notes: ${params.MANUAL_BUILD_REASON ?: ''}"
  enableSlackNotifications('#qa-pipeline-status')
  loadVaultSecrets(secrets)
  handleEnvironmentSetting()
  setFunctionalTestEnvVars()
  enableFortifyScan()

  afterAlways('fortify-scan') {
    steps.archiveArtifacts allowEmptyArchive: true, artifacts: '**/Fortify Scan/**/*'
    runE2ETests(yarnBuilder)
  }
}

/** Latest refs/heads/master on origin (after fetch) — informational only; E2E stages still use checkout scm per matrix node. */
def recordOriginMasterHeadForReference() {
  try {
    node {
      checkout scm
      def fetchRc = sh(
        script: 'git fetch --no-tags --depth=1 origin +refs/heads/master:refs/remotes/origin/master',
        returnStatus: true
      )
      if (fetchRc != 0) {
        echo 'WARNING: git fetch origin master failed; reference SHA may be missing or stale'
      }
      env.ORIGIN_MASTER_HEAD_SHA = sh(
        script: 'git rev-parse refs/remotes/origin/master 2>/dev/null || echo unknown',
        returnStdout: true
      ).trim()
    }
  } catch (Exception e) {
    echo "WARNING: Could not resolve origin/master: ${e.message}"
    env.ORIGIN_MASTER_HEAD_SHA = 'unknown'
  }
  echo "Reference — origin/master at build start: ${env.ORIGIN_MASTER_HEAD_SHA}"
}

def validateInputs() {
  if (params.ENVIRONMENT == 'preview' && (!params.PR_NUMBER?.trim())) {
    error("Validation Failed: PR number is required when environment is 'preview'")
  }
  if (params.ENVIRONMENT == 'preview' && !params.PR_NUMBER.trim().matches("^\\d+\$")) {
    error("Validation Failed: PR number must contain only numerical values")
  }
}

def handleEnvironmentSetting() {
  env.TEST_URL = (params.ENVIRONMENT == 'preview')
    ? "https://pcs-frontend-pr-${params.PR_NUMBER}.preview.platform.hmcts.net"
    : "https://pcs.${params.ENVIRONMENT}.platform.hmcts.net/"
}

def setFunctionalTestEnvVars() {
  env.PCS_API_URL = 'http://pcs-api-aat.service.core-compute-aat.internal'
  env.DATA_STORE_URL_BASE = 'http://ccd-data-store-api-aat.service.core-compute-aat.internal'
  def tag = params.PLAYWRIGHT_GREP_TAG ?: '@nightly'
  env.E2E_TEST_SCOPE = (tag == '(all tests)') ? '' : tag
  env.E2E_SPEC = params.PLAYWRIGHT_SPEC?.trim() ?: ''
  env.ENABLE_ALL_PAGE_FUNCTIONAL_TESTS = params.ENABLE_ALL_PAGE_FUNCTIONAL_TESTS
  env.ENABLE_AXE_AUDIT = params.ENABLE_AXE_AUDIT
}

def runE2ETests(yarnBuilder) {
  def e2eMatrix = [
    [flag: 'CHROME_TESTS', project: 'chrome', browser: 'Chrome', label: 'Desktop Chrome'],
    [flag: 'FIREFOX_TESTS', project: 'firefox', browser: 'Firefox', label: 'Desktop Firefox'],
    [flag: 'WEBKIT_TESTS', project: 'webkit', browser: 'Safari', label: 'Desktop Safari (WebKit)'],
    [flag: 'EDGE_TESTS', project: 'edge', browser: 'Edge', label: 'Desktop Edge'],
    [flag: 'MOBILE_ANDROID_TESTS', project: 'mobile-android', browser: 'MobileAndroid', label: 'Mobile Android (Pixel 5)'],
    [flag: 'MOBILE_IOS_TESTS', project: 'mobile-ios', browser: 'MobileIos', label: 'Mobile iOS (WebKit)'],
    [flag: 'MOBILE_IPAD_TESTS', project: 'mobile-ipad', browser: 'MobileIpad', label: 'Mobile iPad (WebKit)'],
  ]
  e2eMatrix.each { row ->
    if (params[row.flag]) {
      runE2eStage(yarnBuilder, row.project, row.browser, row.label)
    }
  }
}

def runE2eStage(yarnBuilder, String playwrightProject, String browser, String stageLabel) {
  stage("E2E - ${stageLabel}") {
    node {
      checkout scm
      sh 'rm -rf allure-results allure-report'
      catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
        withEnv(["PLAYWRIGHT_PROJECT=${playwrightProject}"]) {
          yarnBuilder.yarn('test:E2e')
        }
      }
      publishHTML([
        allowMissing: true,
        alwaysLinkToLastBuild: true,
        keepAll: true,
        reportDir: "allure-report",
        reportFiles: 'index.html',
        reportName: "Full ${browser} E2E Test Report"
      ])
      steps.archiveArtifacts(
        allowEmptyArchive: true,
        artifacts: 'definitions/test/playwright-report/**'
      )
      sendAllureReportToSlack(stageLabel, "Full_20${browser}_20E2E_20Test_20Report/")
    }
  }
}

def sendAllureReportToSlack(String browser, String reportSuffix) {
  env.E2E_BROWSER = browser
  env.ALLURE_REPORT_PATH_SUFFIX = reportSuffix
  def msg = sh(script: "yarn exec ts-node src/test/ui/utils/common/allure-slack-notifier.ts --print-only --pipeline-type nightly 2>/dev/null || true", returnStdout: true).trim()
  if (!msg) { msg = "E2E Test Results — Build #${env.BUILD_NUMBER} — See ${env.BUILD_URL} for details" }
  try {
    slackSend(channel: '#qa-pipeline-status', message: msg)
  } catch (Exception e) {
    echo "WARNING: Slack notification failed: ${e.message}"
  }
}
