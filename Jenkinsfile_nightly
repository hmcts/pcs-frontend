#!groovy

properties([
  // H allow predefined but random minute see https://en.wikipedia.org/wiki/Cron#Non-standard_characters
  pipelineTriggers([cron('H 07 * * 1-5')]),
  parameters([
    choice(
      name: 'ENVIRONMENT',
      choices: ['aat', 'preview'],
      description: 'Environment to run the test.'
    ),
    string(
      name: 'PR_NUMBER',
      defaultValue: '',
      description: 'PR number (REQUIRED if environment is preview, leave blank otherwise).'
    ),
    booleanParam(
      name: 'CHROME_TESTS',
      defaultValue: true,
      description: 'Tick the checkbox to run E2E tests in Chrome.'
    ),
    booleanParam(
      name: 'FIREFOX_TESTS',
      defaultValue: true,
      description: 'Tick the checkbox to run E2E tests in Firefox.'
    ),
    booleanParam(
      name: 'WEBKIT_TESTS',
      defaultValue: true,
      description: 'Tick the checkbox to run E2E tests in Webkit.'
    ),
    booleanParam(
      name: 'ACCESSIBILITY_TESTS',
      defaultValue: true,
      description: 'Tick the checkbox to run Accessibility tests.'
    ),
    booleanParam(
      name: 'RUN_SAUCE_LABS',
      defaultValue: false,
      description: 'Run Sauce Labs cross-browser (saucectl). Requires Sauce credentials and tunnel on the agent (e.g. SAUCE_TUNNEL_NAME). Note: Jenkins cannot show the matrix dropdown only when this is ticked — the Sauce matrix choice below is ignored when this is unticked.'
    ),
    choice(
      name: 'SAUCE_LABS_MATRIX',
      choices: [
        'macOS 15 - Chrome (latest)',
        'macOS 15 - Firefox (latest)',
        'Windows 11 - Chrome (latest)',
        'Windows 11 - Microsoft Edge (latest)',
        'Windows 11 - Firefox (latest)',
      ].join('\n'),
      description: 'One OS + one browser per Sauce run (when "Run Sauce Labs" is ticked). See .sauce/config-sauce-*.yml (macOS 15 / Windows 11, Playwright 1.58.2).'
    ),
  ])
])

@Library("Infrastructure")

def type = "nodejs"
def product = "pcs"
def component = "frontend"

def yarnBuilder = new uk.gov.hmcts.contino.YarnBuilder(this)

static Map secret(String secretName, String envVariable) {
  [$class     : 'AzureKeyVaultSecret',
   secretType : 'Secret',
   name       : secretName,
   envVariable: envVariable
  ]
}

def secrets = [
  'pcs-${env}': [
    secret('pcs-frontend-idam-secret', 'PCS_FRONTEND_IDAM_SECRET'),
    secret('idam-pcs-user-password', 'IDAM_PCS_USER_PASSWORD')
  ]
]

withNightlyPipeline(type, product, component) {
  validateInputs()
  enableSlackNotifications('#pcs-tech')
  loadVaultSecrets(secrets)
  handleEnvironmentSetting()
  setFunctionalTestEnvVars()
  enableFortifyScan()

  afterAlways('fortify-scan') {
    steps.archiveArtifacts allowEmptyArchive: true, artifacts: '**/Fortify Scan/**/*'
    runE2ETests(yarnBuilder)
    if (params.ACCESSIBILITY_TESTS) {
      runAccessibilityTests(yarnBuilder)
    }
    if (params.RUN_SAUCE_LABS) {
      runSauceLabsMatrix(yarnBuilder)
    }
  }
}

def validateInputs() {
  if (params.ENVIRONMENT == 'preview' && (!params.PR_NUMBER?.trim())) {
    error("Validation Failed: PR number is required when environment is 'preview'")
  }
  if (params.ENVIRONMENT == 'preview' && !params.PR_NUMBER.trim().matches("^\\d+\$")) {
    error("Validation Failed: PR number must contain only numerical values")
  }
}

def handleEnvironmentSetting() {
  env.TEST_URL = (params.ENVIRONMENT == 'preview')
    ? "https://pcs-frontend-pr-${params.PR_NUMBER}.preview.platform.hmcts.net"
    : "https://pcs.${params.ENVIRONMENT}.platform.hmcts.net"
}

def setFunctionalTestEnvVars() {
  env.PCS_API_URL = 'http://pcs-api-aat.service.core-compute-aat.internal'
  env.DATA_STORE_URL_BASE = 'http://ccd-data-store-api-aat.service.core-compute-aat.internal'
}

def runE2ETests(yarnBuilder) {
  env.ENABLE_ALL_PAGE_FUNCTIONAL_TESTS = 'true'
  if (params.CHROME_TESTS) {
    runE2ETestsForBrowser(yarnBuilder, 'Chrome')
  }
  if (params.FIREFOX_TESTS) {
    runE2ETestsForBrowser(yarnBuilder, 'Firefox')
  }
  if (params.WEBKIT_TESTS) {
    runE2ETestsForBrowser(yarnBuilder, 'Safari')
  }
}

def runE2ETestsForBrowser(yarnBuilder, String browser) {
  stage("Full E2E Test - ${browser}") {
    node {
      checkout scm
      sh 'rm -rf allure-results allure-report'
      catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
        yarnBuilder.yarn("test:E2e${browser}")
      }
      publishHTML([
        allowMissing: true,
        alwaysLinkToLastBuild: true,
        keepAll: true,
        reportDir: "allure-report",
        reportFiles: 'index.html',
        reportName: "Full ${browser} E2E Test Report"
      ])
      steps.archiveArtifacts(
        allowEmptyArchive: true,
        artifacts: 'definitions/test/playwright-report/**'
      )
      sendAllureReportToSlack(browser, "Full_20${browser}_20E2E_20Test_20Report/")
    }
  }
}

/** Maps nightly choice to package.json script (see .sauce/*.yml). */
def sauceMatrixToYarnScript(String matrixChoice) {
  switch (matrixChoice) {
    case 'macOS 15 - Chrome (latest)':
      return 'test:sauce:mac15-chrome'
    case 'macOS 15 - Firefox (latest)':
      return 'test:sauce:mac15-firefox'
    case 'Windows 11 - Chrome (latest)':
      return 'test:sauce:win11-chrome'
    case 'Windows 11 - Microsoft Edge (latest)':
      return 'test:sauce:win11-edge'
    case 'Windows 11 - Firefox (latest)':
      return 'test:sauce:win11-firefox'
    default:
      echo "WARNING: Unknown SAUCE_LABS_MATRIX='${matrixChoice}', defaulting to macOS 15 Chrome."
      return 'test:sauce:mac15-chrome'
  }
}

def runSauceLabsMatrix(yarnBuilder) {
  def yarnScript = sauceMatrixToYarnScript(params.SAUCE_LABS_MATRIX)
  stage("Sauce Labs — ${params.SAUCE_LABS_MATRIX}") {
    node {
      checkout scm
      catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
        echo 'Sauce: ensure SAUCE_USERNAME / SAUCE_ACCESS_KEY (or saucectl env) and tunnel SAUCE_TUNNEL_NAME are available on this node.'
        yarnBuilder.yarn(yarnScript)
      }
    }
  }
}

def runAccessibilityTests(yarnBuilder) {
  stage("Full Accessibility Test") {
    node {
      checkout scm
      sh 'rm -rf allure-results allure-report'
      catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
        yarnBuilder.yarn("test:accessibility")
      }
      publishHTML([
        allowMissing         : true,
        alwaysLinkToLastBuild: true,
        keepAll              : true,
        reportDir            : "allure-report",
        reportFiles          : 'index.html',
        reportName           : 'Accessibility Test Report'
      ])
      steps.archiveArtifacts allowEmptyArchive: true, artifacts: 'reports/tests-results/ManageCasesFunctional/*'
      sendAllureReportToSlack('Chrome', 'Accessibility_20Test_20Report/')
    }
  }
}

def sendAllureReportToSlack(String browser, String reportSuffix) {
  env.E2E_BROWSER = browser
  env.ALLURE_REPORT_PATH_SUFFIX = reportSuffix
  def msg = sh(script: "yarn exec ts-node src/test/ui/utils/common/allure-slack-notifier.ts --print-only --pipeline-type nightly 2>/dev/null || true", returnStdout: true).trim()
  if (!msg) { msg = "E2E Test Results — Build #${env.BUILD_NUMBER} — See ${env.BUILD_URL} for details" }
  try {
    slackSend(channel: '#hdp-qa-e2e-test-results', message: msg)
  } catch (Exception e) {
    echo "WARNING: Slack notification failed: ${e.message}"
  }
}
