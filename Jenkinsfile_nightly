#!groovy

properties([
  pipelineTriggers([cron('H 07 * * 1-5')]),
  parameters([
    booleanParam(
      name: 'CHROME_TESTS',
      defaultValue: true,
      description: 'Tick the checkbox to run E2E tests in Desktop Chrome.'
    ),
    booleanParam(
      name: 'FIREFOX_TESTS',
      defaultValue: false,
      description: 'Tick the checkbox to run E2E tests in Desktop Firefox.'
    ),
    booleanParam(
      name: 'WEBKIT_TESTS',
      defaultValue: false,
      description: 'Tick the checkbox to run E2E tests in Desktop WebKit (Safari).'
    ),
    booleanParam(
      name: 'MICROSOFT_EDGE_TESTS',
      defaultValue: false,
      description: 'Tick the checkbox to run E2E tests in Desktop Edge.'
    ),
    booleanParam(
      name: 'ENABLE_ALL_PAGE_FUNCTIONAL_TESTS',
      defaultValue: true,
      description: 'Tick the checkbox to enable page functional tests (content, errors, navigation).'
    ),
    choice(
      name: 'PLAYWRIGHT_GREP_TAG',
      choices: ['@nightly', '(all tests)', '@smoke', '@regression', '@accessibility'],
      description: 'Title tag. Default @nightly. (all tests) = no tag filter.'
    ),
    string(
      name: 'PLAYWRIGHT_SPEC',
      defaultValue: '',
      description: 'Spec path substring (exact case). Blank = all specs.'
    ),
  ])
])

@Library("Infrastructure")

def type = "nodejs"
def product = "pcs"
def component = "frontend"

def yarnBuilder = new uk.gov.hmcts.contino.YarnBuilder(this)

static Map secret(String secretName, String envVariable) {
  [$class     : 'AzureKeyVaultSecret',
   secretType : 'Secret',
   name       : secretName,
   envVariable: envVariable
  ]
}

def secrets = [
  'pcs-${env}': [
    secret('pcs-frontend-idam-secret', 'PCS_FRONTEND_IDAM_SECRET'),
    secret('idam-pcs-user-password', 'IDAM_PCS_USER_PASSWORD')
  ]
]

withNightlyPipeline(type, product, component) {
  enableSlackNotifications('#pcs-tech')
  loadVaultSecrets(secrets)
  setFunctionalTestEnvVars()
  enableFortifyScan()

  afterAlways('fortify-scan') {
    steps.archiveArtifacts allowEmptyArchive: true, artifacts: '**/Fortify Scan/**/*'
    runE2ETests(yarnBuilder)
  }
}

def setFunctionalTestEnvVars() {
  env.TEST_URL = 'https://pcs.aat.platform.hmcts.net/'
  env.PCS_API_URL = 'http://pcs-api-aat.service.core-compute-aat.internal'
  env.DATA_STORE_URL_BASE = 'http://ccd-data-store-api-aat.service.core-compute-aat.internal'
  def tag = params.PLAYWRIGHT_GREP_TAG ?: '@nightly'
  env.FUNCTIONAL_TEST_SCOPE = (tag == '(all tests)') ? '' : tag
  env.E2E_SPEC = params.PLAYWRIGHT_SPEC?.trim() ?: ''
  env.ENABLE_ALL_PAGE_FUNCTIONAL_TESTS = (params.ENABLE_ALL_PAGE_FUNCTIONAL_TESTS != false) ? 'true' : 'false'
}

def runE2ETests(yarnBuilder) {
  [
    [flag: 'CHROME_TESTS', playwrightProject: 'chrome', stageLabel: 'Desktop Chrome'],
    [flag: 'FIREFOX_TESTS', playwrightProject: 'firefox', stageLabel: 'Desktop Firefox'],
    [flag: 'WEBKIT_TESTS', playwrightProject: 'webkit', stageLabel: 'Desktop WebKit'],
    [flag: 'MICROSOFT_EDGE_TESTS', playwrightProject: 'MicrosoftEdge', stageLabel: 'Desktop Edge'],
  ].each { row ->
    if (params[row.flag]) {
      runE2eStage(yarnBuilder, row.playwrightProject, row.stageLabel)
    }
  }
}

def runE2eStage(yarnBuilder, String playwrightProject, String stageLabel) {
  stage("${stageLabel}") {
    node {
      checkout scm
      sh 'rm -rf allure-results allure-report'
      catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
        withEnv(["PLAYWRIGHT_PROJECT=${playwrightProject}"]) {
          yarnBuilder.yarn('test:E2e')
        }
      }
      publishHTML([
        allowMissing: true,
        alwaysLinkToLastBuild: true,
        keepAll: true,
        reportDir: "allure-report",
        reportFiles: 'index.html',
        reportName: "${stageLabel} E2E Report"
      ])
      steps.archiveArtifacts(
        allowEmptyArchive: true,
        artifacts: 'definitions/test/playwright-report/**'
      )
      sendAllureReportToSlack(stageLabel, "Full_20${playwrightProject}_20E2E_20Test_20Report/")
    }
  }
}

def sendAllureReportToSlack(String browser, String reportSuffix) {
  env.E2E_BROWSER = browser
  env.ALLURE_REPORT_PATH_SUFFIX = reportSuffix
  def msg = sh(script: "yarn exec ts-node src/test/ui/scripts/allure-slack-notifier.ts --print-only --pipeline-type nightly 2>/dev/null || true", returnStdout: true).trim()
  if (!msg) { msg = "E2E Test Results — Build #${env.BUILD_NUMBER} — See ${env.BUILD_URL} for details" }
  try {
    slackSend(channel: '#hdp-qa-e2e-test-results', message: msg)
  } catch (Exception e) {
    echo "WARNING: Slack notification failed: ${e.message}"
  }
}
