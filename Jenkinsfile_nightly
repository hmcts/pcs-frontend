#!groovy

properties([
  // H allow predefined but random minute see https://en.wikipedia.org/wiki/Cron#Non-standard_characters
  pipelineTriggers([cron('H 07 * * 1-5')]),
  parameters([
    // 1) Where
    text(
      name: 'MANUAL_BUILD_REASON',
      defaultValue: 'Daily nightly schedule run',
      description: 'Why this build was triggered. For manual runs, enter a short note (e.g. verify a fix, extra browser coverage). Scheduled runs keep the default.'
    ),
    choice(
      name: 'ENVIRONMENT',
      choices: ['aat', 'preview'],
      description: 'Target environment for TEST_URL (AAT or PR preview).'
    ),
    string(
      name: 'PR_NUMBER',
      defaultValue: '',
      description: 'PR number — required when ENVIRONMENT is preview; leave blank for AAT.'
    ),
    // 2) What to run — scope for Jenkins VM E2E (also sets E2E_* env used where applicable)
    choice(
      name: 'PLAYWRIGHT_GREP_TAG',
      choices: ['@nightly', '@smoke', '@e2e', '@regression'],
      description: 'Tag filter for Jenkins VM Playwright runs (sets E2E_TEST_SCOPE). First choice is the scheduled default.'
    ),
    string(
      name: 'PLAYWRIGHT_SPEC',
      defaultValue: '',
      description: 'Jenkins VM only — limit spec files: each keyword must appear in the path of a *.spec.ts under src/test/ui (case-sensitive). Separate with comma or semicolon (e.g. respondToAClaim). Blank = all specs. Sauce uses suite grep only.'
    ),
    choice(
      name: 'ENABLE_ALL_PAGE_FUNCTIONAL_TESTS',
      choices: ['true', 'false'],
      description: 'Run page functional tests (content, errors, navigation). Applies to VM and Sauce.'
    ),
    choice(
      name: 'ENABLE_AXE_AUDIT',
      choices: ['true', 'false'],
      description: 'Run axe accessibility audits during E2E. Applies to VM and Sauce.'
    ),
    // 3) Jenkins VM — which Playwright projects to run on the agent (not Sauce)
    booleanParam(
      name: 'CHROME_TESTS',
      defaultValue: true,
      description: 'Jenkins VM: run E2E in Chrome (default on).'
    ),
    booleanParam(
      name: 'FIREFOX_TESTS',
      defaultValue: false,
      description: 'Jenkins VM: run E2E in Firefox.'
    ),
    booleanParam(
      name: 'WEBKIT_TESTS',
      defaultValue: false,
      description: 'Jenkins VM: run E2E in WebKit (desktop Safari).'
    ),
    booleanParam(
      name: 'EDGE_TESTS',
      defaultValue: false,
      description: 'Jenkins VM: run E2E in Microsoft Edge.'
    ),
    booleanParam(
      name: 'MOBILE_ANDROID_TESTS',
      defaultValue: false,
      description: 'Jenkins VM: run E2E on Android (Pixel 5) profile.'
    ),
    booleanParam(
      name: 'MOBILE_IOS_TESTS',
      defaultValue: false,
      description: 'Jenkins VM: run E2E on iOS (iPhone 12) WebKit profile.'
    ),
    booleanParam(
      name: 'MOBILE_IPAD_TESTS',
      defaultValue: false,
      description: 'Jenkins VM: run E2E on iPad Pro 11 WebKit profile.'
    ),
    // 4) Sauce Labs — tag filter then platform matrix (see .sauce/config-sauce-nightly.yml suite names). Suite toggles default off.
    string(
      name: 'SAUCE_GREP',
      defaultValue: '@crossbrowser',
      description: 'Sauce only — Playwright title grep for saucectl when at least one suite below is enabled (e.g. @crossbrowser).'
    ),
    booleanParam(
      name: 'SAUCE_MAC13_CHROME',
      defaultValue: false,
      description: 'Sauce suite: macOS 13 — Chrome (pcs-frontend-mac13-chrome). Default off.'
    ),
    booleanParam(
      name: 'SAUCE_MAC13_FIREFOX',
      defaultValue: false,
      description: 'Sauce suite: macOS 13 — Firefox (pcs-frontend-mac13-firefox). Default off.'
    ),
    booleanParam(
      name: 'SAUCE_MAC_SAFARI',
      defaultValue: false,
      description: 'Sauce suite: macOS 13 — WebKit / Safari engine (pcs-frontend-mac13-webkit). Default off.'
    ),
    booleanParam(
      name: 'SAUCE_WIN11_CHROME',
      defaultValue: false,
      description: 'Sauce suite: Windows 11 — Chrome (pcs-frontend-win11-chrome). Default off.'
    ),
    booleanParam(
      name: 'SAUCE_WIN11_EDGE',
      defaultValue: false,
      description: 'Sauce suite: Windows 11 — Edge (pcs-frontend-win11-edge). Default off.'
    ),
    booleanParam(
      name: 'SAUCE_WIN11_FIREFOX',
      defaultValue: false,
      description: 'Sauce suite: Windows 11 — Firefox (pcs-frontend-win11-firefox). Default off.'
    ),
  ])
])

@Library("Infrastructure")

def type = "nodejs"
def product = "pcs"
def component = "frontend"

def yarnBuilder = new uk.gov.hmcts.contino.YarnBuilder(this)

static Map secret(String secretName, String envVariable) {
  [$class     : 'AzureKeyVaultSecret',
   secretType : 'Secret',
   name       : secretName,
   envVariable: envVariable
  ]
}

def secrets = [
  'pcs-${env}': [
    secret('pcs-frontend-idam-secret', 'PCS_FRONTEND_IDAM_SECRET'),
    secret('idam-pcs-user-password', 'IDAM_PCS_USER_PASSWORD'),
    secret('idam-pcs-user-password-b64', 'IDAM_PCS_USER_PASSWORD_B64'),
    secret('pcs-solicitor-automation-uid', 'PCS_SOLICITOR_AUTOMATION_UID')
  ]
]

withNightlyPipeline(type, product, component) {
  validateInputs()
  enableSlackNotifications('#qa-pipeline-status')
  loadVaultSecrets(secrets)
  handleEnvironmentSetting()
  setFunctionalTestEnvVars()
  enableFortifyScan()
  def sauceSuites = selectedSauceSuites()
  if (!sauceSuites.isEmpty()) {
    // Mint S2S + IDAM on the agent (internal URLs); pass into saucectl so Playwright on Sauce skips token HTTP.
    yarnBuilder.yarn('mint:e2e-tokens-for-sauce')
    def mintPath = '.sauce/minted-tokens.json'
    if (fileExists(mintPath)) {
      def t = readJSON file: mintPath
      if (t.SERVICE_AUTH_TOKEN) {
        env.SERVICE_AUTH_TOKEN = t.SERVICE_AUTH_TOKEN.toString()
      }
      if (t.BEARER_TOKEN) {
        env.BEARER_TOKEN = t.BEARER_TOKEN.toString()
      }
      if (t.S2S_URL) {
        env.S2S_URL = t.S2S_URL.toString()
      }
      if (t.IDAM_WEB_URL) {
        env.IDAM_WEB_URL = t.IDAM_WEB_URL.toString()
      }
      if (t.IDAM_TESTING_SUPPORT_URL) {
        env.IDAM_TESTING_SUPPORT_URL = t.IDAM_TESTING_SUPPORT_URL.toString()
      }
      sh 'rm -f .sauce/minted-tokens.json'
    }
    env.SAUCE_SUITE_NAMES = sauceSuites.join(' ')
    enableCrossBrowserTest()
  }

  afterAlways('fortify-scan') {
    steps.archiveArtifacts allowEmptyArchive: true, artifacts: '**/Fortify Scan/**/*'
    runE2ETests(yarnBuilder)
  }
}

def selectedSauceSuites() {
  [
    params.SAUCE_MAC13_CHROME ? 'pcs-frontend-mac13-chrome' : null,
    params.SAUCE_MAC13_FIREFOX ? 'pcs-frontend-mac13-firefox' : null,
    params.SAUCE_MAC_SAFARI ? 'pcs-frontend-mac13-webkit' : null,
    params.SAUCE_WIN11_CHROME ? 'pcs-frontend-win11-chrome' : null,
    params.SAUCE_WIN11_EDGE ? 'pcs-frontend-win11-edge' : null,
    params.SAUCE_WIN11_FIREFOX ? 'pcs-frontend-win11-firefox' : null,
  ].findAll { it != null }
}

def validateInputs() {
  if (params.ENVIRONMENT == 'preview' && (!params.PR_NUMBER?.trim())) {
    error("Validation Failed: PR number is required when environment is 'preview'")
  }
  if (params.ENVIRONMENT == 'preview' && !params.PR_NUMBER.trim().matches("^\\d+\$")) {
    error("Validation Failed: PR number must contain only numerical values")
  }
}

def handleEnvironmentSetting() {
  env.TEST_URL = (params.ENVIRONMENT == 'preview')
    ? "https://pcs-frontend-pr-${params.PR_NUMBER}.preview.platform.hmcts.net"
    : "https://pcs.${params.ENVIRONMENT}.platform.hmcts.net/"
}

def setFunctionalTestEnvVars() {
  env.PCS_API_URL = 'http://pcs-api-aat.service.core-compute-aat.internal'
  env.DATA_STORE_URL_BASE = 'http://ccd-data-store-api-aat.service.core-compute-aat.internal'
  env.SAUCE_GREP = (params.SAUCE_GREP?.trim()) ?: '@crossbrowser'
  def tag = params.PLAYWRIGHT_GREP_TAG?.trim() ?: '@nightly'
  env.E2E_TEST_SCOPE = tag
  env.E2E_SPEC = params.PLAYWRIGHT_SPEC?.trim() ?: ''
  env.ENABLE_ALL_PAGE_FUNCTIONAL_TESTS = params.ENABLE_ALL_PAGE_FUNCTIONAL_TESTS
  env.ENABLE_AXE_AUDIT = params.ENABLE_AXE_AUDIT
}

def runE2ETests(yarnBuilder) {
  def e2eMatrix = [
    [flag: 'CHROME_TESTS', project: 'chrome', browser: 'Chrome', label: 'Desktop Chrome'],
    [flag: 'FIREFOX_TESTS', project: 'firefox', browser: 'Firefox', label: 'Desktop Firefox'],
    [flag: 'WEBKIT_TESTS', project: 'webkit', browser: 'Safari', label: 'Desktop Safari (WebKit)'],
    [flag: 'EDGE_TESTS', project: 'edge', browser: 'Edge', label: 'Desktop Edge'],
    [flag: 'MOBILE_ANDROID_TESTS', project: 'mobile-android', browser: 'MobileAndroid', label: 'Mobile Android (Pixel 5)'],
    [flag: 'MOBILE_IOS_TESTS', project: 'mobile-ios', browser: 'MobileIos', label: 'Mobile iOS (WebKit)'],
    [flag: 'MOBILE_IPAD_TESTS', project: 'mobile-ipad', browser: 'MobileIpad', label: 'Mobile iPad (WebKit)'],
  ]
  e2eMatrix.each { row ->
    if (params[row.flag]) {
      runE2eStage(yarnBuilder, row.project, row.browser, row.label)
    }
  }
}

def runE2eStage(yarnBuilder, String playwrightProject, String browser, String stageLabel) {
  stage("E2E - ${stageLabel}") {
    node {
      checkout scm
      sh 'rm -rf allure-results allure-report'
      catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
        withEnv(["PLAYWRIGHT_PROJECT=${playwrightProject}"]) {
          yarnBuilder.yarn('test:E2e')
        }
      }
      publishHTML([
        allowMissing: true,
        alwaysLinkToLastBuild: true,
        keepAll: true,
        reportDir: "allure-report",
        reportFiles: 'index.html',
        reportName: "Full ${browser} E2E Test Report"
      ])
      steps.archiveArtifacts(
        allowEmptyArchive: true,
        artifacts: 'definitions/test/playwright-report/**'
      )
      sendAllureReportToSlack(stageLabel, "Full_20${browser}_20E2E_20Test_20Report/")
    }
  }
}

def sendAllureReportToSlack(String browser, String reportSuffix) {
  env.E2E_BROWSER = browser
  env.ALLURE_REPORT_PATH_SUFFIX = reportSuffix
  def msg = sh(script: "yarn exec ts-node src/test/ui/utils/common/allure-slack-notifier.ts --print-only --pipeline-type nightly 2>/dev/null || true", returnStdout: true).trim()
  if (!msg) { msg = "E2E Test Results — Build #${env.BUILD_NUMBER} — See ${env.BUILD_URL} for details" }
  try {
    slackSend(channel: '#qa-pipeline-status', message: msg)
  } catch (Exception e) {
    echo "WARNING: Slack notification failed: ${e.message}"
  }
}
