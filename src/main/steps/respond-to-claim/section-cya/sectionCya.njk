{% extends "stepsTemplate.njk" %}

{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "macros/stepButtons.njk"                   import stepButtons %}
{% from "macros/csrf.njk"                          import csrfProtection %}

{% block pageTitle %}{{ summaryData.cardTitle }} &ndash; {{ t('pageTitle') }} &ndash; HM Courts &amp; Tribunals Service &ndash; GOV.UK{% endblock %}

{% block mainContent %}
  <h1 class="govuk-heading-l">{{ t('pageTitle') }}</h1>

  <div class="govuk-summary-card">
    <div class="govuk-summary-card__title-wrapper">
      <h2 class="govuk-summary-card__title">
        {{ summaryData.cardTitle }}
      </h2>
    </div>
    <div class="govuk-summary-card__content">
      {% if summaryData.renderRowsAsPresentation %}
        <div class="govuk-summary-list" role="presentation">
          {% for row in summaryData.rows %}
            <div class="govuk-summary-list__row{% if row.classes %} {{ row.classes }}{% endif %}" role="presentation">
              <div class="govuk-summary-list__key{% if row.key.classes %} {{ row.key.classes }}{% endif %}">
                {% if row.key.html %}
                  {{ row.key.html | safe }}
                {% else %}
                  {{ row.key.text }}
                {% endif %}
              </div>
              <div class="govuk-summary-list__value{% if row.value.classes %} {{ row.value.classes }}{% endif %}">
                {% if row.value.html %}
                  {{ row.value.html | safe }}
                {% else %}
                  {{ row.value.text }}
                {% endif %}
              </div>
              {% if row.actions and row.actions.items.length %}
                <div class="govuk-summary-list__actions{% if row.actions.classes %} {{ row.actions.classes }}{% endif %}">
                  {% if row.actions.items.length == 1 %}
                    <a class="govuk-link{% if row.actions.items[0].classes %} {{ row.actions.items[0].classes }}{% endif %}" href="{{ row.actions.items[0].href }}">
                      {{ row.actions.items[0].text }}{% if row.actions.items[0].visuallyHiddenText %}<span class="govuk-visually-hidden"> {{ row.actions.items[0].visuallyHiddenText }}</span>{% endif %}
                    </a>
                  {% else %}
                    <ul class="govuk-summary-list__actions-list">
                      {% for action in row.actions.items %}
                        <li class="govuk-summary-list__actions-list-item">
                          <a class="govuk-link{% if action.classes %} {{ action.classes }}{% endif %}" href="{{ action.href }}">
                            {{ action.text }}{% if action.visuallyHiddenText %}<span class="govuk-visually-hidden"> {{ action.visuallyHiddenText }}</span>{% endif %}
                          </a>
                        </li>
                      {% endfor %}
                    </ul>
                  {% endif %}
                </div>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      {% else %}
        {{ govukSummaryList({ rows: summaryData.rows }) }}
      {% endif %}
    </div>
  </div>

  <form method="post" action="{{ formAction }}" novalidate>
    {{ csrfProtection(csrfToken) }}
    {{ stepButtons(t('buttons.saveAndContinue'), t('buttons.saveForLater')) }}
  </form>
{% endblock %}
