{% extends "stepsTemplate.njk" %}
{% from "macros/stepButtons.njk" import stepButtons %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "macros/csrf.njk" import csrfProtection %}
{% block mainContent %}
  {% if errorSummary %}
    {{ govukErrorSummary(errorSummary) }}
  {% endif %}
  <h1 class="govuk-heading-l">Check your answers (placeholder)</h1>
  <p class="govuk-body">This is a placeholder for Check your answers step.</p>
  <form id="submitResponse" method="POST" action="/case/{{ ccdId }}/final-submit" novalidate>
    <button type="submit" class="govuk-button" data-module="govuk-button">
      Submit
    </button>
    {{ csrfProtection(csrfToken) }}
  </form>
{% endblock %}