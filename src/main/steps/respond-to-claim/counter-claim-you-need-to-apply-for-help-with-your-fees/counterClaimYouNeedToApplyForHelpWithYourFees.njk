{% extends "stepsTemplate.njk" %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "macros/csrf.njk" import csrfProtection %}

{% block pageTitle %}{{ pageTitle }} &ndash; HM Courts &amp; Tribunals Service &ndash; GOV.UK{% endblock %}

{% block mainContent %}
  {% if caption %}
    <span class="govuk-caption-l">{{ caption }}</span>
  {% endif %}
  {% if heading %}
    <h1 class="govuk-heading-l">{{ heading }}</h1>
  {% endif %}

  <p class="govuk-body">{{ youNeedToApplyBeforeContinuing | safe }}</p>
  <p class="govuk-body">{{ enterCourtFormNumber }}</p>
  <p class="govuk-body">{{ afterYouHaveApplied }}</p>
  <p class="govuk-body">{{ ifYouReceiveAnyBenefit }}</p>
  <p class="govuk-body">{{ ifYouHaveYourHWFReference | safe }}</p>

  <form method="post" action="{{ url }}">
    <div class="govuk-button-group">
      {{ govukButton({
        text: saveForLater,
        classes: 'govuk-button--secondary',
        attributes: { name: 'action', value: 'saveForLater' }
      }) }}
    </div>
    {{ csrfProtection(csrfToken) }}
  </form>
{% endblock %}
