{% extends "stepsTemplate.njk" %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "moj/components/multi-file-upload/macro.njk" import mojMultiFileUpload %}
{% from "macros/stepButtons.njk" import stepButtons %}
{% from "macros/csrf.njk" import csrfProtection %}

{% block pageTitle %}
  {{ title }} &ndash; HM Courts &amp; Tribunals Service &ndash; GOV.UK
{% endblock %}

{% block mainContent %}
  {% if errorSummary %}
    {{ govukErrorSummary(errorSummary) }}
  {% endif %}

  {% if caption %}
    <span class="govuk-caption-l">{{ caption }}</span>
  {% endif %}

  {% if title %}
    <h1 class="govuk-heading-l">{{ title }}</h1>
  {% endif %}

  {% if introText %}
    <p class="govuk-body">{{ introText }}</p>
  {% endif %}

  {% if beforeYouUploadHeading %}
    <p class="govuk-body govuk-!-font-weight-bold">{{ beforeYouUploadHeading }}</p>
  {% endif %}

  {% if namingInstruction %}
    <p class="govuk-body">{{ namingInstruction }}</p>
  {% endif %}

  <form method="post" action="{{ url }}" {% if hasFileFields %}enctype="multipart/form-data"{% endif %}>
    {% for field in fields %}
      {% if field.component and field.componentType == 'multiFileUpload' %}
        {{ mojMultiFileUpload(field.component) }}
      {% endif %}
    {% endfor %}
    {{ stepButtons(saveAndContinue, saveForLater) }}
    {{ csrfProtection(csrfToken) }}
  </form>
{% endblock %}