{% extends "stepsTemplate.njk" %}

{% block pageTitle %}{{ t('pageTitle') }} &ndash; HM Courts &amp; Tribunals Service &ndash; GOV.UK{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-l">{{ propertyAddress }}</h1>
      <p class="govuk-body">{{ t('caseNumberLabel') }} {{ caseNumber }}</p>
    </div>
  </div>

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds pcs-task-list">
      <hr class="govuk-section-break govuk-section-break--xl govuk-section-break--visible pcs-task-list__divider">

      {# Status sits inside the link (visually-hidden) so it isn't read twice with the visible tag. #}
      {% for group in groups %}
        <h2 class="govuk-heading-m">{{ group.number }}. {{ group.title }}</h2>
        <ul class="govuk-task-list">
          {% for item in group.items %}
            <li class="govuk-task-list__item{% if item.href %} govuk-task-list__item--with-link{% endif %}">
              <div class="govuk-task-list__name-and-hint">
                {% if item.href %}
                  <a class="govuk-link govuk-task-list__link" href="{{ item.href }}">
                    {{ item.title.text }}<span class="govuk-visually-hidden"> &ndash; {{ item.status.tag.text }}</span>
                  </a>
                {% else %}
                  <div>{{ item.title.text }}<span class="govuk-visually-hidden"> &ndash; {{ item.status.tag.text }}</span></div>
                {% endif %}
              </div>
              <div class="govuk-task-list__status" aria-hidden="true">
                <strong class="govuk-tag{% if item.status.tag.classes %} {{ item.status.tag.classes }}{% endif %}">{{ item.status.tag.text }}</strong>
              </div>
            </li>
          {% endfor %}
        </ul>
      {% endfor %}
    </div>

    <div class="govuk-grid-column-one-third">
      <hr class="govuk-section-break govuk-section-break--xl govuk-section-break--visible pcs-task-list__divider">
      <aside class="app-related-items" aria-label="{{ t('sidebarLabel') }}">
        <h2 class="govuk-heading-m">{{ t('iWantTo.heading') }}</h2>
        <ul class="govuk-list">
          {% for link in iWantToLinks %}
            {% set isExternal = link.href.startsWith('http') %}
            <li>
              <a class="govuk-link" href="{{ link.href }}"{% if isExternal %} target="_blank" rel="noopener noreferrer"{% endif %}>
                {{ t(link.key) }}{% if isExternal %}<span class="govuk-visually-hidden"> ({{ t('opensInNewTab') }})</span>{% endif %}
              </a>
            </li>
          {% endfor %}
        </ul>

        <h2 class="govuk-heading-m">{{ t('helpSupport.heading') }}</h2>
        <ul class="govuk-list">
          {% for link in helpSupportLinks %}
            <li>
              <a class="govuk-link" href="{{ link.href }}" target="_blank" rel="noopener noreferrer">
                {{ t(link.key) }}<span class="govuk-visually-hidden"> ({{ t('opensInNewTab') }})</span>
              </a>
            </li>
          {% endfor %}
        </ul>

        {% include "components/contact-us-details.njk" %}
      </aside>
    </div>
  </div>
{% endblock %}
