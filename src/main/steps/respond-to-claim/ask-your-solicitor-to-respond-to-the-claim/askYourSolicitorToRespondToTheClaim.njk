{% extends "stepsTemplate.njk" %}
{% from "macros/stepButtons.njk" import stepButtons %}
{% from "macros/csrf.njk" import csrfProtection %}

{% block pageTitle %}{{ pageTitle }} - HM Courts &amp; Tribunals Service &ndash; GOV.UK{% endblock %}

{% block mainContent %}
  <h1 class="govuk-heading-l">{{ heading }}</h1>

  <p class="govuk-body">{{ paragraph1 }}</p>

  <form method="post" action="{{ url }}">
    {{ stepButtons(saveAndContinue, saveForLater) }}
    {{ csrfProtection(csrfToken) }}
  </form>

  <p class="govuk-body">
    <a href="{{ dashboardUrl }}" class="govuk-button govuk-button--secondary">{{ closeAndReturnToTaskList }}</a>
  </p>
{% endblock %}
