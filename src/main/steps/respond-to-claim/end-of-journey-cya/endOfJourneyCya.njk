{% extends "stepsTemplate.njk" %}
{% from "govuk/components/error-summary/macro.njk"  import govukErrorSummary %}
{% from "govuk/components/summary-list/macro.njk"   import govukSummaryList %}
{% from "govuk/components/checkboxes/macro.njk"     import govukCheckboxes %}
{% from "govuk/components/input/macro.njk"          import govukInput %}
{% from "govuk/components/character-count/macro.njk" import govukCharacterCount %}
{% from "govuk/components/button/macro.njk"         import govukButton %}
{% from "macros/csrf.njk"                           import csrfProtection %}

{% block pageTitle %}{{ pageTitle }} &ndash; HM Courts &amp; Tribunals Service &ndash; GOV.UK{% endblock %}

{% block mainContent %}
  {% if errorSummary %}
    {{ govukErrorSummary(errorSummary) }}
  {% endif %}

  <h1 class="govuk-heading-l">{{ heading }}</h1>

  {% for section in sections %}
    {% if section.rows.length > 0 %}
      {{ govukSummaryList({
        card: { title: { text: section.heading } },
        rows: section.rows
      }) }}
    {% endif %}
  {% endfor %}

  <form method="post" action="{{ url }}" novalidate>
    {{ csrfProtection(csrfToken) }}
    <input type="hidden" name="isLegalRepresentative" value="{{ 'true' if isLegalRepresentative else 'false' }}">

    <h2 class="govuk-heading-m">{{ statementOfTruthHeading }}</h2>
    <p class="govuk-body">{{ statementOfTruthHint }}</p>

    {% if isLegalRepresentative %}
      {# Legal rep: first field (contemptOfCourt) is rendered as plain text, not a checkbox #}
      {% for field in fields %}
        {% if field.name == 'statementOfTruthContempt' %}
          <p class="govuk-body">{{ field.component.items[0].text }}</p>
        {% endif %}
      {% endfor %}

      {# Legal rep: belief checkbox with legal-rep specific wording #}
      {% for field in fields %}
        {% if field.componentType == 'checkboxes' and field.name != 'statementOfTruthContempt' %}
          {{ govukCheckboxes(field.component) }}
        {% endif %}
      {% endfor %}
    {% else %}
      {# Citizen: both checkboxes rendered normally #}
      {% for field in fields %}
        {% if field.componentType == 'checkboxes' %}
          {{ govukCheckboxes(field.component) }}
        {% endif %}
      {% endfor %}
    {% endif %}

    {# fullName is always shown; nameOfFirm and positionHeld only shown for legal reps #}
    {% for field in fields %}
      {% if field.componentType == 'input' %}
        {% if field.name == 'fullName' or isLegalRepresentative %}
          {{ govukInput(field.component) }}
        {% endif %}
      {% endif %}
    {% endfor %}

    <div class="govuk-button-group">
      {{ govukButton({
        text: t('buttons.submit', { ns: 'common' }),
        attributes: { type: 'submit' },
        preventDoubleClick: true
      }) }}
      <p class="govuk-body">
        <a href="{{ dashboardUrl }}" class="govuk-link">{{ t('buttons.cancel', { ns: 'common' }) }}</a>
      </p>
    </div>
  </form>
{% endblock %}
