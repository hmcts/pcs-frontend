{% extends "stepsTemplate.njk" %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "macros/csrf.njk" import csrfProtection %}
{% from "macros/fileUploadMoj.njk" import fileUploadMoj %}

{% block pageTitle %}
  {{ pageTitle }} &ndash; HM Courts &amp; Tribunals Service &ndash; GOV.UK
{% endblock %}

{% block mainContent %}
  <style>
    .moj-multi-file-upload__button { display: none; }
  </style>

  {% if errorSummary %}
    {{ govukErrorSummary(errorSummary) }}
  {% endif %}

  {% if heading %}
    <h1 class="govuk-heading-l">{{ heading }}</h1>
  {% endif %}

  <p class="govuk-body">{{ guidanceText }}</p>
  <p class="govuk-body">{{ beforeUploadText }}</p>
  <p class="govuk-body">{{ fileTypesText }}</p>

  <form method="post" action="{{ url }}" novalidate>
    {% for field in fields %}
      {% if field.componentType == 'fileUpload' %}
        {{ fileUploadMoj(
          field.component,
          field.component.uploadButtonText,
          field.component.filesAddedHeading,
          field.component.value
        ) }}
      {% endif %}
    {% endfor %}

    <div class="govuk-button-group">
      {{ govukButton({
        text: continue,
        attributes: { name: 'action', value: 'continue' }
      }) }}
      {% if showCancelButton is not defined or showCancelButton %}
        <a href="{{ dashboardUrl }}" class="govuk-link">{{ cancel }}</a>
      {% endif %}
    </div>
    {{ csrfProtection(csrfToken) }}
  </form>
{% endblock %}
