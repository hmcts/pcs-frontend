{% extends "stepsTemplate.njk" %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "macros/csrf.njk" import csrfProtection %}

{% block pageTitle %}{{ t('pageTitle') }} - HM Courts & Tribunals Service – GOV.UK{% endblock %}

{% block mainContent %}
  {% if errorSummary %}
    {{ govukErrorSummary(errorSummary) }}
  {% endif %}

  <h1 class="govuk-heading-l">{{ heading }}</h1>

  <p class="govuk-body">{{ paragraph1 }}</p>
  <p class="govuk-body">{{ paragraph2 }}</p>

  <form method="post" action="{{ url }}" novalidate>
    {{ govukRadios({
      idPrefix: "relatedApplicationId",
      name: "relatedApplicationId",
      fieldset: {
        legend: {
          text: question,
          classes: "govuk-fieldset__legend--m"
        }
      },
      errorMessage: radioErrorMessage,
      items: applications
    }) }}
    <div class="govuk-button-group">
      {{ govukButton({
        text: t('buttons.continue', 'Continue')
      }) }}
      <p class="govuk-body">
        <a href="{{ cancelUrl }}" class="govuk-link">{{ t('buttons.cancel', { ns: 'common' }) }}</a>
      </p>
    </div>
    {{ csrfProtection(csrfToken) }}
  </form>
{% endblock %}
