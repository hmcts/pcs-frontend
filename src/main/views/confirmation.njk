{% extends "template.njk" %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <div class="govuk-notification-banner" role="region" aria-labelledby="experimental-banner">
        <div class="govuk-notification-banner__content">
          <p class="govuk-notification-banner__heading" id="experimental-banner">
            This is a development placeholder page for testing purposes only.
          </p>
        </div>
      </div>

      <div class="govuk-panel govuk-panel--confirmation">
        <h1 class="govuk-panel__title">Response Submitted</h1>
        <div class="govuk-panel__body">
          Case ID<br>
          <strong>{{ caseId }}</strong>
        </div>
      </div>
    </div>
  </div>
{% endblock %}
