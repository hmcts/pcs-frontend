{% extends "template.njk" %}
{% from "macros/csrf.njk" import csrfProtection %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      {% if errorList and errorList.length %}
        <div class="govuk-error-summary" data-module="govuk-error-summary">
          <div role="alert">
            <h2 class="govuk-error-summary__title">
              There is a problem
            </h2>
            <div class="govuk-error-summary__body">
              <ul class="govuk-list govuk-error-summary__list">
                {% for item in errorList %}
                  <li>
                    <a href="{{ item.href }}">{{ item.text }}</a>
                  </li>
                {% endfor %}
              </ul>
            </div>
          </div>
        </div>
      {% endif %}

      <h1 class="govuk-heading-l">Access your case</h1>

      <p class="govuk-body">Access and manage your case using your claim number and access code. These will be in letter, email or pack sent by the court.</p>

      <form method="POST" action="/access-your-case" novalidate>
        {{ csrfProtection(csrfToken) }}

        <div class="govuk-form-group {% if errors.claimNumber %}govuk-form-group--error{% endif %}">
          <label class="govuk-label govuk-label--m" for="claimNumber">
            Enter your claim number
          </label>
          <div class="govuk-hint">
            This is a 16-digit number
          </div>
          {% if errors.claimNumber %}
            <p id="claimNumber-error" class="govuk-error-message">
              <span class="govuk-visually-hidden">Error:</span> {{ errors.claimNumber.text }}
            </p>
          {% endif %}
          <input
            class="govuk-input govuk-input--width-20 {% if errors.claimNumber %}govuk-input--error{% endif %}"
            id="claimNumber"
            name="claimNumber"
            type="text"
            value="{{ claimNumber }}"
            autocomplete="off"
            {% if errors.claimNumber %}aria-describedby="claimNumber-error"{% endif %}
          >
        </div>

        <div class="govuk-form-group {% if errors.accessCode %}govuk-form-group--error{% endif %}">
          <label class="govuk-label govuk-label--m" for="accessCode">
            Enter your access code
          </label>
          <div class="govuk-hint">
            This has 8 characters
          </div>
          {% if errors.accessCode %}
            <p id="accessCode-error" class="govuk-error-message">
              <span class="govuk-visually-hidden">Error:</span> {{ errors.accessCode.text }}
            </p>
          {% endif %}
          <input
            class="govuk-input govuk-input--width-20 {% if errors.accessCode %}govuk-input--error{% endif %}"
            id="accessCode"
            name="accessCode"
            type="text"
            value="{{ accessCode }}"
            autocomplete="off"
            {% if errors.accessCode %}aria-describedby="accessCode-error"{% endif %}
          >
        </div>

        <button type="submit" class="govuk-button" data-module="govuk-button">
          Continue
        </button>
      </form>

    </div>
  </div>
{% endblock %}
