{% extends "template.njk" %}

{% block head %}
  {{ super() }}
  <script type="module" src="{{ headerShell.assets.scripts[0] }}"></script>
  {% if footerShell %}
    <script type="module" src="{{ footerShell.assets.scripts[0] }}"></script>
  {% endif %}
{% endblock %}

{% block header %}
  {{ headerShell.html | safe }}
{% endblock %}

{% block content %}
<div class="govuk-width-container">
  <main class="govuk-main-wrapper" id="content" role="main">
    <div class="width-50">
      <span class="govuk-caption-l">Demo</span>
      <h1 class="govuk-heading-l">PUI header shell</h1>
      <p class="govuk-body">Simple form underneath the Manage Cases header web component.</p>

      <form method="get" action="/pui-demo" class="govuk-!-margin-bottom-6">
        <input type="hidden" name="theme" value="{{ nextTheme | default('judicial') }}">
        <button class="govuk-button govuk-button--secondary" type="submit">
          Switch to {{ nextTheme | default('judicial') }} theme
        </button>
      </form>

      <form method="post" action="#">
        <div class="govuk-form-group">
          <label class="govuk-label" for="demo-name">Name</label>
          <input class="govuk-input govuk-!-width-two-thirds" id="demo-name" name="demo-name" type="text" autocomplete="name">
        </div>

        <div class="govuk-form-group">
          <label class="govuk-label" for="demo-case-reference">Case reference</label>
          <input class="govuk-input govuk-input--width-20" id="demo-case-reference" name="demo-case-reference" type="text" inputmode="numeric" autocomplete="off">
        </div>

        <div class="govuk-form-group">
          <label class="govuk-label" for="demo-notes">Notes</label>
          <textarea class="govuk-textarea" id="demo-notes" name="demo-notes" rows="5"></textarea>
        </div>

        <button class="govuk-button" data-module="govuk-button" type="submit">Submit</button>
      </form>
    </div>
  </main>
</div>
{% endblock %}

{% block footer %}
  {% if footerShell %}
    {{ footerShell.html | safe }}
  {% endif %}
{% endblock %}
