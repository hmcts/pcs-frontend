{% extends "template.njk" %}
{% from "govuk/components/footer/macro.njk" import govukFooter %}

{% block head %}
  {{ super() }}
  <script type="module" src="{{ headerShell.assets.scripts[0] }}"></script>
{% endblock %}

{% block header %}
  {{ headerShell.html | safe }}
{% endblock %}

{% block content %}
<div class="govuk-width-container">
  <main class="govuk-main-wrapper" id="content" role="main">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-two-thirds">
        {% set paymentList = payments | default([
          { instance: 'Payment 1', dueDate: '31/01/2025', amountDue: '£125', amountPaid: '£0' },
          { instance: 'Payment 2', dueDate: '27/02/2025', amountDue: '£125', amountPaid: '£0' },
          { instance: 'Payment 3', dueDate: '31/03/2025', amountDue: '£125', amountPaid: '£0' },
          { instance: 'Payment 4', dueDate: '30/04/2025', amountDue: '£125', amountPaid: '£0' },
          { instance: 'Payment 5', dueDate: '31/05/2025', amountDue: '£125', amountPaid: '£0' },
          { instance: 'Payment 6', dueDate: '30/06/2025', amountDue: '£125', amountPaid: '£0' }
        ], true) %}
        {% set arrearsTotal = totalArrears | default('£750') %}
        {% set reference = caseReference | default('1234-5678-9101') %}
        <span class="govuk-caption-l">Make a claim</span>
        <h1 class="govuk-heading-l">Payment history</h1>
        <p class="govuk-body govuk-!-margin-bottom-2">{{ reference }}</p>

        <table class="govuk-table">
          <caption class="govuk-table__caption govuk-table__caption--m govuk-visually-hidden">Payment history</caption>
          <thead class="govuk-table__head">
            <tr class="govuk-table__row">
              <th scope="col" class="govuk-table__header">Payment instance</th>
              <th scope="col" class="govuk-table__header">Due date</th>
              <th scope="col" class="govuk-table__header">Amount due</th>
              <th scope="col" class="govuk-table__header">Amount paid</th>
              <th scope="col" class="govuk-table__header govuk-table__header--numeric">Change</th>
              <th scope="col" class="govuk-table__header govuk-table__header--numeric">Remove</th>
            </tr>
          </thead>
          <tbody class="govuk-table__body">
            {% for payment in paymentList %}
              <tr class="govuk-table__row">
                <th scope="row" class="govuk-table__header">{{ payment.instance }}</th>
                <td class="govuk-table__cell">{{ payment.dueDate }}</td>
                <td class="govuk-table__cell">{{ payment.amountDue }}</td>
                <td class="govuk-table__cell">{{ payment.amountPaid }}</td>
                <td class="govuk-table__cell govuk-table__cell--numeric">
                  <a class="govuk-link" href="#">Change<span class="govuk-visually-hidden"> payment {{ payment.instance }}</span></a>
                </td>
                <td class="govuk-table__cell govuk-table__cell--numeric">
                  <a class="govuk-link" href="{{ basePath }}?theme={{ themeName }}{% for removed in removeList | default([]) %}&remove={{ removed | urlencode }}{% endfor %}&remove={{ payment.instance | urlencode }}">
                    Remove<span class="govuk-visually-hidden"> payment {{ payment.instance }}</span>
                  </a>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>

        <form method="get" action="{{ basePath }}/check-answers">
          <input type="hidden" name="theme" value="{{ themeName | default('case-manager') }}">
          {% for removed in removeList | default([]) %}
            <input type="hidden" name="remove" value="{{ removed }}">
          {% endfor %}
          <p class="govuk-heading-m govuk-!-margin-top-6 govuk-!-margin-bottom-3">
            Total accumulated arrears: {{ arrearsTotal }}
          </p>

          <div class="govuk-form-group">
            <fieldset class="govuk-fieldset">
              <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">
                <h2 class="govuk-fieldset__heading">Do you need to add another missed payment?</h2>
              </legend>
              <div class="govuk-radios" data-module="govuk-radios">
                <div class="govuk-radios__item">
                  <input class="govuk-radios__input" id="add-payment-yes" name="add-payment" type="radio" value="yes">
                  <label class="govuk-label govuk-radios__label" for="add-payment-yes">Yes</label>
                </div>
                <div class="govuk-radios__item">
                  <input class="govuk-radios__input" id="add-payment-no" name="add-payment" type="radio" value="no" checked>
                  <label class="govuk-label govuk-radios__label" for="add-payment-no">No</label>
                </div>
              </div>
            </fieldset>
          </div>

          <div class="govuk-button-group">
            <button class="govuk-button" data-module="govuk-button" type="submit">Continue</button>
            <button class="govuk-button govuk-button--secondary" data-module="govuk-button" type="button">Previous</button>
            <a class="govuk-link" href="http://localhost:3000/cases/case-details/PCS/PCS/{{ caseReference | urlencode }}">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </main>
</div>
{% endblock %}

{% block footer %}
  {{ govukFooter({}) }}
{% endblock %}

{% block bodyEnd %}
  {{ super() }}
  <script>
    (() => {
      const getShellRoot = () => {
        const shell = document.querySelector('hmcts-header-shell');
        return shell && (shell.shadowRoot || shell.querySelector('template[shadowrootmode="open"]')?.content);
      };

      const getNavList = () => {
        const root = getShellRoot();
        return root && root.querySelector('.hmcts-primary-navigation__list');
      };

      const ensureMyWorkNav = () => {
        const list = getNavList();
        if (!list) return false;
        const items = Array.from(list.querySelectorAll('.hmcts-primary-navigation__item'));
        const exists = items.some(item => item.textContent && item.textContent.trim().toLowerCase() === 'my work');
        if (!exists) {
          const li = document.createElement('li');
          li.className = 'hmcts-primary-navigation__item';
          const link = document.createElement('a');
          link.className = 'hmcts-primary-navigation__link';
          link.href = '/work';
          const span = document.createElement('span');
          span.className = 'hmcts-primary-navigation__link-text';
          span.textContent = 'My work';
          link.appendChild(span);
          li.appendChild(link);
          list.insertBefore(li, list.firstChild);
        }
        return true;
      };

      const trimNavToCreateCase = () => {
        const list = getNavList();
        if (!list) return false;

        const items = Array.from(list.querySelectorAll('.hmcts-primary-navigation__item'));
        const createCase = items.find(item => /Create case/i.test(item.textContent || ''));
        if (!createCase) return false;

        if (list.firstElementChild !== createCase || list.children.length !== 1) {
          list.innerHTML = '';
          list.appendChild(createCase);
        }
        ensureMyWorkNav();
        return true;
      };

      const setupObserver = () => {
        const list = getNavList();
        if (!list) return false;

        trimNavToCreateCase();
        const observer = new MutationObserver(() => {
          trimNavToCreateCase();
          ensureMyWorkNav();
        });
        observer.observe(list, { childList: true });
        return true;
      };

      const adjustPhaseBannerPadding = () => {
        const root = getShellRoot();
        const phaseText = root && root.querySelector('.govuk-phase-banner__text');
        if (!phaseText) return false;

        phaseText.style.paddingLeft = '0';
        return true;
      };

      const start = () => {
        adjustPhaseBannerPadding();
        ensureMyWorkNav();
        if (setupObserver()) return;

        let attempts = 0;
        const interval = setInterval(() => {
          const observerReady = setupObserver();
          adjustPhaseBannerPadding();
          ensureMyWorkNav();
          if (observerReady || attempts >= 50) {
            clearInterval(interval);
          }
          attempts += 1;
        }, 200);
      };

      if (document.readyState === 'complete' || document.readyState === 'interactive') {
        start();
      } else {
        document.addEventListener('DOMContentLoaded', start);
      }
    })();
  </script>
{% endblock %}
