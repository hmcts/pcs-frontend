{% extends "template.njk" %}
{% from "govuk/components/footer/macro.njk" import govukFooter %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/textarea/macro.njk" import govukTextarea %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/date-input/macro.njk" import govukDateInput %}
{% from "govuk/components/checkboxes/macro.njk" import govukCheckboxes %}

{% block head %}
  {{ super() }}
  <script type="module" src="{{ headerShell.assets.scripts[0] }}"></script>
{% endblock %}

{% block header %}
  {{ headerShell.html | safe }}
{% endblock %}

{% block content %}
<div class="govuk-width-container orders-demo">
  <div class="govuk-grid-row govuk-!-margin-bottom-2">
    <div class="govuk-grid-column-full">
      <p class="govuk-body-s govuk-!-margin-bottom-0">
        <strong class="govuk-tag govuk-tag--blue">V1</strong>
        Baseline demo.
        <a class="govuk-link" href="{{ otherVersionUrl }}">Switch to V2</a>
      </p>
    </div>
  </div>
  <main class="govuk-main-wrapper orders-demo__main" id="content" role="main">
    <div class="orders-demo__panel">
      <form class="orders-demo__form" action="{{ basePath }}" method="post" novalidate>
        <input type="hidden" name="generatedPreviewText" value="">
        <input type="hidden" name="generatedPreviewStatus" value="">
        <div class="orders-demo__top-grid orders-demo__top-grid--sticky">
          <div class="orders-demo__summary">
            <p class="govuk-caption-l govuk-!-margin-bottom-1">Case</p>
            <h1 class="govuk-heading-l govuk-!-margin-bottom-1">Make an order</h1>
            <p class="govuk-body govuk-!-margin-bottom-1 govuk-!-font-weight-bold">{{ caseReference | default('1234-5678-9101') }}</p>
            <p class="govuk-body govuk-!-margin-bottom-4">{{ caseTitle | default('Smith v Jones') }}</p>
            {% if submitted %}
              <div class="govuk-inset-text govuk-!-margin-top-2 govuk-!-margin-bottom-2">
                Order submitted to CCD.
              </div>
            {% endif %}
          </div>

          <div class="orders-demo__judicial">
            <div class="orders-demo__section-header">
              <h2 class="govuk-heading-m govuk-!-margin-bottom-1">Judicial Notes (Tenancy)</h2>
              <p class="govuk-body-s govuk-!-margin-bottom-3">
                Last updated {{ lastUpdated | default('25/10/2025') }} by {{ lastUpdatedBy | default('DJ Daley') }}
              </p>
            </div>

            <div class="orders-demo__input-grid">
              {{ govukInput({
                label: { text: "Date of tenancy", classes: "govuk-label--s" },
                classes: "govuk-input--width-10",
                name: "dateOfTenancy",
                value: dateOfTenancy | default('01/05/2020'),
                attributes: { placeholder: "DD/MM/YYYY" }
              }) }}
              {{ govukInput({
                label: { text: "Date notice s/vd", classes: "govuk-label--s" },
                classes: "govuk-input--width-10",
                name: "dateNotice",
                value: dateNoticeServed | default('15/09/2024'),
                attributes: { placeholder: "DD/MM/YYYY" }
              }) }}
              {{ govukInput({
                label: { text: "Grounds", classes: "govuk-label--s" },
                name: "grounds",
                classes: "govuk-input--width-20",
                value: grounds | default('8, 10, 11'),
                attributes: { placeholder: "eg 8, 10, 11 or NTQ" }
              }) }}
              {{ govukInput({
                label: { text: "Arrears on issue", classes: "govuk-label--s" },
                classes: "govuk-input--width-10",
                prefix: { text: "£" },
                name: "arrearsOnIssue",
                value: arrearsOnIssue | default('825.00'),
                attributes: { placeholder: "0.00" }
              }) }}
            </div>

            <div class="orders-demo__input-grid">
              {{ govukInput({
                label: { text: "Arrears at notice", classes: "govuk-label--s" },
                classes: "govuk-input--width-10",
                prefix: { text: "£" },
                name: "arrearsAtNotice",
                value: arrearsAtNotice | default('1100.00'),
                attributes: { placeholder: "0.00" }
              }) }}
              {{ govukInput({
                label: { text: "Arrears at hearing", classes: "govuk-label--s" },
                classes: "govuk-input--width-10",
                prefix: { text: "£" },
                name: "arrearsAtHearing",
                value: arrearsAtHearing | default('1250.00'),
                attributes: { placeholder: "0.00" }
              }) }}
              {{ govukInput({
                label: { text: "Current rent", classes: "govuk-label--s" },
                classes: "govuk-input--width-10",
                prefix: { text: "£" },
                name: "currentRent",
                value: currentRent | default('550.00'),
                attributes: { placeholder: "0.00" }
              }) }}
              <div class="orders-demo__inline-select">
                <p class="govuk-body govuk-!-margin-bottom-0">per</p>
                <select class="govuk-select govuk-select--small" name="currentRentFrequency">
                  <option value="month" {{ 'selected' if currentRentFrequency == 'month' }}>month</option>
                  <option value="quarter" {{ 'selected' if currentRentFrequency == 'quarter' }}>quarter</option>
                  <option value="year" {{ 'selected' if currentRentFrequency == 'year' }}>year</option>
                </select>
              </div>
            </div>
          </div>

          <div class="orders-demo__hearing">
            <h2 class="govuk-heading-m govuk-!-margin-bottom-2">Hearing Notes</h2>
            {{ govukTextarea({
              label: { text: "Add notes for the bench", classes: "govuk-label--s" },
              name: "hearingNotes",
              classes: "govuk-textarea--small",
              attributes: { rows: "4" }
            }) }}
          </div>
        </div>

        <div class="orders-demo__section orders-demo__section--attendance">
          <h2 class="govuk-heading-m govuk-!-margin-bottom-2">Attendance</h2>
          <table class="orders-demo__attendance-table">
            <thead>
              <tr>
                <th class="govuk-table__header">Party</th>
                <th class="govuk-table__header">Counsel</th>
                <th class="govuk-table__header">Solicitor</th>
                <th class="govuk-table__header">S/A</th>
                <th class="govuk-table__header">H/O</th>
                <th class="govuk-table__header">Duty</th>
                <th class="govuk-table__header">LiP</th>
                <th class="govuk-table__header">Not present</th>
                <th class="govuk-table__header">Name</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th class="govuk-table__header">{{ "Claimant (" + claimantName + ")" }}</th>
                <td class="govuk-table__cell">
                  <input type="radio" name="claimantAttendance" value="counsel" id="claimant-counsel">
                  <label for="claimant-counsel" class="govuk-visually-hidden">Claimant</label>
                </td>
                <td class="govuk-table__cell">
                  <input type="radio" name="claimantAttendance" value="solicitor" id="claimant-solicitor" checked>
                  <label for="claimant-solicitor" class="govuk-visually-hidden">Claimant</label>
                </td>
                <td class="govuk-table__cell">
                  <input type="radio" name="claimantAttendance" value="solicitorAgent" id="claimant-agent">
                  <label for="claimant-agent" class="govuk-visually-hidden">Claimant</label>
                </td>
                <td class="govuk-table__cell">
                  <input type="radio" name="claimantAttendance" value="housingOfficerRep" id="claimant-ho-rep">
                  <label for="claimant-ho-rep" class="govuk-visually-hidden">Claimant</label>
                </td>
                <td class="govuk-table__cell">
                  <input type="radio" name="claimantAttendance" value="duty" id="claimant-duty">
                  <label for="claimant-duty" class="govuk-visually-hidden">Claimant</label>
                </td>
                <td class="govuk-table__cell">
                  <input type="radio" name="claimantAttendance" value="lip" id="claimant-lip">
                  <label for="claimant-lip" class="govuk-visually-hidden">Claimant</label>
                </td>
                <td class="govuk-table__cell">
                  <input type="radio" name="claimantAttendance" value="absent" id="claimant-absent">
                  <label for="claimant-absent" class="govuk-visually-hidden">Claimant</label>
                </td>
                <td class="govuk-table__cell">
                  <input class="govuk-input govuk-input--width-10 govuk-input--small" name="claimantAttendanceName" type="text" value="A. Solicitor" aria-label="Claimant name">
                </td>
              </tr>
              {% for defendant in defendants %}
                {% set idx = loop.index %}
                <tr>
                  <th class="govuk-table__header">{{ "Defendant (" + defendant + ")" }}</th>
                  <td class="govuk-table__cell">
                    <input type="radio" name="defendant-{{ idx }}-attendance" value="counsel" id="defendant-{{ idx }}-counsel">
                    <label for="defendant-{{ idx }}-counsel" class="govuk-visually-hidden">Defendant</label>
                  </td>
                  <td class="govuk-table__cell">
                    <input type="radio" name="defendant-{{ idx }}-attendance" value="solicitor" id="defendant-{{ idx }}-solicitor">
                    <label for="defendant-{{ idx }}-solicitor" class="govuk-visually-hidden">Defendant</label>
                  </td>
                  <td class="govuk-table__cell">
                    <input type="radio" name="defendant-{{ idx }}-attendance" value="solicitorAgent" id="defendant-{{ idx }}-agent">
                    <label for="defendant-{{ idx }}-agent" class="govuk-visually-hidden">Defendant</label>
                  </td>
                  <td class="govuk-table__cell">
                    <input type="radio" name="defendant-{{ idx }}-attendance" value="housingOfficerRep" id="defendant-{{ idx }}-ho-rep">
                    <label for="defendant-{{ idx }}-ho-rep" class="govuk-visually-hidden">Defendant</label>
                  </td>
                  <td class="govuk-table__cell">
                    <input type="radio" name="defendant-{{ idx }}-attendance" value="duty" id="defendant-{{ idx }}-duty">
                    <label for="defendant-{{ idx }}-duty" class="govuk-visually-hidden">Defendant</label>
                  </td>
                  <td class="govuk-table__cell">
                    <input type="radio" name="defendant-{{ idx }}-attendance" value="lip" id="defendant-{{ idx }}-lip" checked>
                    <label for="defendant-{{ idx }}-lip" class="govuk-visually-hidden">Defendant</label>
                  </td>
                  <td class="govuk-table__cell">
                    <input type="radio" name="defendant-{{ idx }}-attendance" value="absent" id="defendant-{{ idx }}-absent">
                    <label for="defendant-{{ idx }}-absent" class="govuk-visually-hidden">Defendant</label>
                  </td>
                  <td class="govuk-table__cell">
                    <input class="govuk-input govuk-input--width-10 govuk-input--small" name="defendant-{{ idx }}-attendance-name" type="text" value="{{ defendant }}" aria-label="Defendant name">
                  </td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>

        <div class="orders-demo__section orders-demo__section--orders">
          <div class="orders-demo__order-switcher">
            {{ govukRadios({
              idPrefix: "order",
              name: "orderType",
              classes: "govuk-radios--small govuk-radios--inline",
              items: [
                { value: "outright", text: "Outright", checked: true },
                { value: "suspended", text: "Suspended" },
                { value: "adjourned", text: "Adjourned" }
              ]
            }) }}
          </div>

          <div class="orders-demo__order-panel" data-order="outright">
            <h2 class="govuk-heading-m govuk-!-margin-bottom-2">Outright possession</h2>
            {{ govukRadios({
              name: "outrightTiming",
              classes: "govuk-radios--small",
              items: [
                { value: "forthwith", text: "Outright possession (forthwith)", checked: true },
                {
                  value: "byDate",
                  text: "Outright possession by",
                  conditional: {
                    html: govukDateInput({
                      id: "outrightBy",
                      namePrefix: "outrightBy",
                      fieldset: { legend: { text: "Possession date", classes: "govuk-visually-hidden" } },
                      items: [
                        { name: "day", classes: "govuk-input--width-2", attributes: { placeholder: "DD" } },
                        { name: "month", classes: "govuk-input--width-2", attributes: { placeholder: "MM" } },
                        { name: "year", classes: "govuk-input--width-4", attributes: { placeholder: "YYYY" } }
                      ]
                    })
                  }
                }
              ]
            }) }}
          </div>

          <div class="orders-demo__order-panel" data-order="suspended" hidden>
            <h2 class="govuk-heading-m govuk-!-margin-bottom-2">Suspended possession</h2>
            {{ govukDateInput({
              id: "suspendedBy",
              namePrefix: "suspendedBy",
              fieldset: { legend: { text: "Possession date", classes: "govuk-label--s" } },
              items: [
                { name: "day", classes: "govuk-input--width-2", attributes: { placeholder: "DD" } },
                { name: "month", classes: "govuk-input--width-2", attributes: { placeholder: "MM" } },
                { name: "year", classes: "govuk-input--width-4", attributes: { placeholder: "YYYY" } }
              ]
            }) }}

            <div class="orders-demo__checkbox-row">
              <input type="checkbox" name="arrearsCheckbox" value="1" id="arrearsCheckbox" checked>
              <label for="arrearsCheckbox">Suspended on payment of arrears of</label>
              {{ govukInput({
                label: { text: "Arrears amount", classes: "govuk-visually-hidden" },
                classes: "govuk-input--width-10 govuk-input--small",
                prefix: { text: "£" },
                name: "arrearsAmount",
                value: "1250.00",
                attributes: { placeholder: "0.00" }
              }) }}
              <span>by</span>
              {{ govukInput({
                label: { text: "Due by", classes: "govuk-visually-hidden" },
                classes: "govuk-input--width-10 govuk-input--small",
                name: "arrearsDueBy",
                value: "30/12/2025",
                attributes: { placeholder: "DD/MM/YYYY" }
              }) }}
            </div>

            <div class="orders-demo__checkbox-row">
              <input type="checkbox" name="initialPaymentCheckbox" value="1" id="initialPaymentCheckbox">
              <label for="initialPaymentCheckbox">by</label>
              {{ govukInput({
                label: { text: "Initial payment", classes: "govuk-visually-hidden" },
                classes: "govuk-input--width-10 govuk-input--small",
                prefix: { text: "£" },
                name: "initialPayment",
                attributes: { placeholder: "0.00" }
              }) }}
              <span>by</span>
              {{ govukInput({
                label: { text: "Initial payment by", classes: "govuk-visually-hidden" },
                classes: "govuk-input--width-10 govuk-input--small",
                name: "initialPaymentBy",
                attributes: { placeholder: "DD/MM/YYYY" }
              }) }}
            </div>

            <div class="orders-demo__checkbox-row">
              <input type="checkbox" name="instalmentCheckbox" value="1" id="instalmentCheckbox">
              <label for="instalmentCheckbox">instalments of</label>
              {{ govukInput({
                label: { text: "Instalment amount", classes: "govuk-visually-hidden" },
                classes: "govuk-input--width-10 govuk-input--small",
                prefix: { text: "£" },
                name: "instalmentAmount",
                attributes: { placeholder: "0.00" }
              }) }}
              <span>per</span>
              <select class="govuk-select govuk-select--small" name="instalmentFrequency">
                <option value="week">week</option>
                <option value="month" selected>month</option>
                <option value="year">year</option>
              </select>
              <span>by</span>
              {{ govukInput({
                label: { text: "Instalment due by", classes: "govuk-visually-hidden" },
                classes: "govuk-input--width-10 govuk-input--small",
                name: "instalmentDueBy",
                attributes: { placeholder: "DD/MM/YYYY" }
              }) }}
            </div>
          </div>

          <div class="orders-demo__order-panel" data-order="adjourned" hidden>
            <h2 class="govuk-heading-m govuk-!-margin-bottom-2">Adjournment</h2>
            {{ govukDateInput({
              id: "adjournNextHearing",
              namePrefix: "adjournNextHearing",
              fieldset: { legend: { text: "Next hearing date", classes: "govuk-label--s" } },
              items: [
                { name: "day", classes: "govuk-input--width-2", attributes: { placeholder: "DD" } },
                { name: "month", classes: "govuk-input--width-2", attributes: { placeholder: "MM" } },
                { name: "year", classes: "govuk-input--width-4", attributes: { placeholder: "YYYY" } }
              ]
            }) }}
            <div class="orders-demo__date-shortcuts">
              <button class="govuk-button govuk-button--secondary govuk-!-margin-right-1" type="button" data-date-shortcut="adjournNextHearing" data-days="14">+14</button>
              <button class="govuk-button govuk-button--secondary govuk-!-margin-right-1" type="button" data-date-shortcut="adjournNextHearing" data-days="21">+21</button>
              <button class="govuk-button govuk-button--secondary govuk-!-margin-right-1" type="button" data-date-shortcut="adjournNextHearing" data-days="28">+28</button>
              <button class="govuk-button govuk-button--secondary" type="button" data-date-shortcut="adjournNextHearing" data-days="42">+42</button>
            </div>
            <div class="orders-demo__input-grid">
              {{ govukInput({
                label: { text: "Time estimate", classes: "govuk-label--s" },
                classes: "govuk-input--width-10",
                name: "adjournTimeEstimate",
                value: "10 mins"
              }) }}
              {{ govukInput({
                label: { text: "Time of day", classes: "govuk-label--s" },
                classes: "govuk-input--width-10",
                name: "adjournTime",
                value: "10:00"
              }) }}
              {{ govukInput({
                label: { text: "Hearing type", classes: "govuk-label--s" },
                classes: "govuk-input--width-20",
                name: "adjournHearingType",
                value: "Possession"
              }) }}
              {{ govukInput({
                label: { text: "Location", classes: "govuk-label--s" },
                classes: "govuk-input--width-20",
                name: "adjournLocation",
                value: "Bristol"
              }) }}
            </div>
            {{ govukTextarea({
              label: { text: "Directions", classes: "govuk-label--s" },
              name: "adjournDirections",
              classes: "govuk-textarea--small",
              attributes: { rows: "5" }
            }) }}
            {{ govukTextarea({
              label: { text: "Reason for adjournment", classes: "govuk-label--s" },
              name: "adjournReason",
              classes: "govuk-textarea--small",
              attributes: { rows: "3" }
            }) }}
          </div>
        </div>

        <div class="orders-demo__section orders-demo__section--costs">
          <h3 class="govuk-heading-s govuk-!-margin-bottom-2">Costs</h3>
          <div class="orders-demo__costs-grid">
            <div class="orders-demo__costs-choice">
              {{ govukRadios({
                name: "costsMode",
                idPrefix: "costs",
                classes: "govuk-radios--small",
                items: [
                  { value: "fixed", text: "Fixed costs (standard)", checked: true },
                  { value: "assessed", text: "Summarily assessed" }
                ]
              }) }}
            </div>
            <div class="orders-demo__costs-details">
              <div data-costs-fixed>
                {{ govukInput({
                  label: { text: "Total costs to be paid by Defendant", classes: "govuk-label--s" },
                  classes: "govuk-input--width-10",
                  prefix: { text: "£" },
                  name: "costsFixedAmount",
                  value: "424.50",
                  attributes: { placeholder: "0.00" }
                }) }}
              </div>
              <div data-costs-assessed hidden>
                {{ govukInput({
                  label: { text: "Total costs to be paid by Defendant", classes: "govuk-label--s" },
                  classes: "govuk-input--width-10",
                  prefix: { text: "£" },
                  name: "costsAssessedAmount",
                  attributes: { placeholder: "0.00" }
                }) }}
                {{ govukInput({
                  label: { text: "Basis of assessment", classes: "govuk-label--s" },
                  classes: "govuk-input--width-20",
                  name: "costsAssessedBasis"
                }) }}
              </div>
              {{ govukInput({
                label: { text: "Pay by", classes: "govuk-label--s" },
                classes: "govuk-input--width-10",
                name: "costsPayBy",
                value: "30/12/2025",
                attributes: { placeholder: "DD/MM/YYYY" }
              }) }}
              <div class="orders-demo__checkbox-row">
                <input type="checkbox" name="costsAddToDebt" value="1" id="costsAddToDebt" checked>
                <label for="costsAddToDebt">Add to judgment debt</label>
              </div>
            </div>
          </div>
        </div>

        <div class="orders-demo__section orders-demo__section--preview">
          <button class="govuk-button govuk-button--secondary orders-demo__preview-toggle" type="button" data-preview-toggle aria-expanded="false">
            <span aria-hidden="true">▶</span> Preview draft order
          </button>
          <div class="orders-demo__preview" hidden>
            <div class="orders-demo__preview-generated" data-preview-generated></div>
            <textarea class="govuk-textarea govuk-textarea--small" rows="10" hidden data-preview-textarea name="previewFreeText"></textarea>
            <button class="govuk-button govuk-button--secondary" type="button" data-preview-edit>Edit as free text</button>
          </div>
          <button class="govuk-button govuk-!-margin-top-4" type="submit">Make order</button>
        </div>
      </form>
    </div>
  </main>
</div>
{% endblock %}

{% block footer %}
  {{ footerShell.html | safe }}
{% endblock %}

{% block scripts %}
  {{ super() }}
  <script>
    (() => {
      const waitFor = (selector, callback) => {
        const element = document.querySelector(selector);
        if (element) return callback(element);
        const observer = new MutationObserver(() => {
          const found = document.querySelector(selector);
          if (found) {
            observer.disconnect();
            callback(found);
          }
        });
        observer.observe(document.body, { childList: true, subtree: true });
      };

      const disableHeaderLinks = () => {
        document.querySelectorAll('a[disabled], a[aria-disabled="true"]').forEach(link => {
          link.addEventListener('click', event => event.preventDefault());
        });
      };

      const adjustPhaseBannerPadding = () => {
        const banner = document.querySelector('.govuk-phase-banner');
        if (!banner) return;
        banner.classList.add('govuk-!-padding-top-2', 'govuk-!-padding-bottom-2');
      };

      const ensureMyWorkNav = () => {
        const nav = document.querySelector('.hmcts-primary-navigation__list');
        if (!nav) return;
        const hasMyWork = Array.from(nav.querySelectorAll('a')).some(a => a.textContent?.trim() === 'My work');
        if (hasMyWork) return;
        const li = document.createElement('li');
        li.className = 'hmcts-primary-navigation__item';
        li.innerHTML = '<a class="hmcts-primary-navigation__link" href="/work"><span class="hmcts-primary-navigation__link-text">My work</span></a>';
        nav.prepend(li);
      };

      const initOrderSwitcher = () => {
        const radios = document.querySelectorAll('input[name="orderType"]');
        const panels = document.querySelectorAll('[data-order]');
        const update = () => {
          const checked = document.querySelector('input[name="orderType"]:checked');
          panels.forEach(panel => {
            const order = panel.getAttribute('data-order');
            panel.hidden = order !== checked?.value;
          });
        };
        radios.forEach(radio => radio.addEventListener('change', update));
        update();
      };

      const initDateShortcuts = () => {
        document.querySelectorAll('[data-date-shortcut]').forEach(button => {
          button.addEventListener('click', () => {
            const target = button.getAttribute('data-date-shortcut');
            const days = parseInt(button.getAttribute('data-days') || '0', 10);
            const fieldset = document.getElementById(target);
            if (!fieldset) return;
            const dayInput = fieldset.querySelector('input[name$="-day"]');
            const monthInput = fieldset.querySelector('input[name$="-month"]');
            const yearInput = fieldset.querySelector('input[name$="-year"]');
            const date = new Date();
            date.setDate(date.getDate() + days);
            if (dayInput) dayInput.value = String(date.getDate()).padStart(2, '0');
            if (monthInput) monthInput.value = String(date.getMonth() + 1).padStart(2, '0');
            if (yearInput) yearInput.value = String(date.getFullYear());
            fieldset.querySelector('input')?.dispatchEvent(new Event('input', { bubbles: true }));
          });
        });
      };

      const initPreview = () => {
        const toggle = document.querySelector('[data-preview-toggle]');
        const preview = document.querySelector('.orders-demo__preview');
        if (!(toggle instanceof HTMLButtonElement) || !(preview instanceof HTMLElement)) return;
        toggle.addEventListener('click', () => {
          const expanded = toggle.getAttribute('aria-expanded') === 'true';
          toggle.setAttribute('aria-expanded', expanded ? 'false' : 'true');
          preview.hidden = expanded;
        });
      };

      const syncArrearsFields = () => {
        const checkbox = document.getElementById('arrearsCheckbox');
        const amount = document.querySelector('input[name="arrearsAmount"]');
        const dueBy = document.querySelector('input[name="arrearsDueBy"]');
        if (!(checkbox instanceof HTMLInputElement) || !(amount instanceof HTMLInputElement) || !(dueBy instanceof HTMLInputElement)) return;
        const update = () => {
          amount.disabled = !checkbox.checked;
          dueBy.disabled = !checkbox.checked;
        };
        checkbox.addEventListener('change', update);
        update();
      };

      const buildPreview = () => {
        const orderType = document.querySelector('input[name="orderType"]:checked')?.value || 'outright';
        const claimantMode = document.querySelector('input[name="claimantAttendance"]:checked')?.value || '';
        const hasDefendant = Array.from(document.querySelectorAll('input[name^="defendant-"][name$="-attendance"]:checked')).some(
          input => input.value !== 'absent'
        );
        const hearing = `Upon hearing the ${claimantMode === 'solicitor' ? 'Solicitor for the Claimant' : 'Claimant'} and the ${
          hasDefendant ? 'Defendant in Person' : 'Defendant not attending'
        }.`;
        const possessionDate = (() => {
          const day = document.querySelector('input[name="outrightBy-day"]')?.value;
          const month = document.querySelector('input[name="outrightBy-month"]')?.value;
          const year = document.querySelector('input[name="outrightBy-year"]')?.value;
          return day && month && year ? `${day}/${month}/${year}` : '30/12/2025';
        })();
        const lines = [];
        if (orderType === 'outright') {
          lines.push(`1. The Defendant give the Claimant possession of 12 High Street, Bristol on or before ${possessionDate}.`);
        }
        if (orderType === 'suspended') {
          lines.push(`1. The Defendant give the Claimant possession of 12 High Street, Bristol on or before 30/12/2025.`);
          lines.push(`2. This order is not to be enforced so long as the Defendant complies with the terms set out below.`);
        }
        if (orderType === 'adjourned') {
          lines.push('1. The claim is adjourned.');
        }
        const costsMode = document.querySelector('input[name="costsMode"]:checked')?.value;
        if (costsMode === 'fixed') {
          lines.push(`Costs: fixed costs to be paid by the Defendant.`);
        }
        if (costsMode === 'assessed') {
          lines.push(`Costs: summarily assessed.`);
        }
        return { text: `${hearing}\n\nIT IS ORDERED THAT:\n\n${lines.join('\n')}`, status: `${orderType} order draft generated` };
      };

      const updatePreview = () => {
        const { text, status } = buildPreview();
        const container = document.querySelector('[data-preview-generated]');
        const button = document.querySelector('[data-preview-toggle]');
        if (container) container.textContent = text;
        if (button instanceof HTMLButtonElement) {
          button.textContent = 'Preview draft order';
          const hint = document.createElement('span');
          hint.className = 'govuk-hint govuk-!-margin-left-2';
          hint.textContent = status;
          button.appendChild(hint);
        }
      };

      const initCostsRadios = () => {
        const update = () => {
          const mode = document.querySelector('input[name="costsMode"]:checked')?.value;
          const fixed = document.querySelector('[data-costs-fixed]');
          const assessed = document.querySelector('[data-costs-assessed]');
          if (fixed instanceof HTMLElement) fixed.hidden = mode !== 'fixed';
          if (assessed instanceof HTMLElement) assessed.hidden = mode !== 'assessed';
        };
        document.querySelectorAll('input[name="costsMode"]').forEach(radio => radio.addEventListener('change', update));
        update();
      };

      const initOrderClickTargets = () => {
        document.querySelectorAll('.govuk-radios__label').forEach(label => {
          label.addEventListener('click', () => {
            const forId = label.getAttribute('for');
            const input = forId ? document.getElementById(forId) : null;
            if (input instanceof HTMLInputElement) input.click();
          });
        });
      };

      const initStandardDirections = () => {};
      const initQuickReasons = () => {};

      const setupObserver = () => {
        const headerNav = document.querySelector('.hmcts-primary-navigation');
        if (!headerNav) return false;

        waitFor('.orders-demo__form', () => {
          initDateShortcuts();
          initOrderClickTargets();
          initStandardDirections();
          initQuickReasons();
          initCostsRadios();
          initPreview();

          const form = document.querySelector('.orders-demo__form');
          const generatedPreviewInput = document.querySelector('input[name="generatedPreviewText"]');
          const generatedPreviewStatusInput = document.querySelector('input[name="generatedPreviewStatus"]');
          if (form) {
            form.addEventListener('input', updatePreview);
            form.addEventListener('change', updatePreview);
            form.addEventListener('submit', event => {
              event.preventDefault();
              const { text, status } = buildPreview();
              const freeText = document.querySelector('[data-preview-textarea]');
              const editedText =
                freeText instanceof HTMLTextAreaElement && !freeText.hidden && freeText.value ? freeText.value : '';

              if (generatedPreviewInput instanceof HTMLInputElement) {
                generatedPreviewInput.value = editedText || text;
              }
              if (generatedPreviewStatusInput instanceof HTMLInputElement) {
                generatedPreviewStatusInput.value = status || '';
              }
            });
          }
        });

        return true;
      };

      const start = () => {
        adjustPhaseBannerPadding();
        initOrderSwitcher();
        ensureMyWorkNav();
        syncArrearsFields();
        disableHeaderLinks();
        if (setupObserver()) return;

        let attempts = 0;
        const interval = setInterval(() => {
          const observerReady = setupObserver();
          adjustPhaseBannerPadding();
          initOrderSwitcher();
          ensureMyWorkNav();
          disableHeaderLinks();
          if (observerReady || attempts >= 50) {
            clearInterval(interval);
          }
          attempts += 1;
        }, 200);
      };

      if (document.readyState === 'complete' || document.readyState === 'interactive') {
        start();
      } else {
        document.addEventListener('DOMContentLoaded', start);
      }
    })();
  </script>
{% endblock %}

