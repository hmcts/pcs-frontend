{% extends "template.njk" %}
{% from "govuk/components/service-navigation/macro.njk" import govukServiceNavigation %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}

{# GOV.UK summary list with card (Design System macro) — document list by folder. #}

{% macro folderDocumentsCard(folder, caseReference, submittedOnLabel) %}
  {% set rows = [] %}
  {% for document in folder.documents %}
    {% set valueHtml %}
<a class="govuk-link" href="/case/{{ caseReference }}/view-documents/{{ document.id }}" target="_blank" rel="noopener noreferrer">{{ document.filename }}</a>
{% if document.submittedOn %}
<div class="govuk-hint govuk-!-margin-bottom-2">{{ submittedOnLabel }} {{ document.submittedOn | date }}</div>
{% endif %}
{% endset %}
    {% set rows = rows.concat([{
      key: {
        text: t('dashboard:viewDocuments.documentLabel', 'Document'),
        classes: 'govuk-visually-hidden'
      },
      value: {
        html: valueHtml,
        classes: 'govuk-!-width-full'
      },
      actions: {
        items: []
      }
    }]) %}
  {% endfor %}
  {{ govukSummaryList({
    card: {
      title: {
        text: folder.title,
        headingLevel: 2
      },
      actions: {
        items: []
      },
      classes: 'govuk-!-margin-bottom-6'
    },
    rows: rows
  }) }}
{% endmacro %}

{% block serviceNavigation %}
  {{ govukServiceNavigation({
    serviceName: t('dashboard:serviceName'),
    serviceUrl: dashboardUrl if dashboardUrl else "/dashboard",
    navigation: [
      {
        text: t('logout', 'Log out'),
        href: "/logout"
      }
    ],
    navigationLabel: t('navigationLabel', 'Service navigation'),
    navigationClasses: "pcs-service-navigation-wrapper"
  }) }}
{% endblock %}

{% block pageTitle %}
{{ t('dashboard:viewDocuments.pageTitle') }}
{% endblock %}

{% block content %}
  {% set submittedOnLabel = t('dashboard:viewDocuments.submittedOn') %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
      <h1 class="govuk-heading-l">{{ t('dashboard:viewDocuments.pageTitle') }}</h1>
      <p class="govuk-body-m">
        {{ t('dashboard:caseReferenceLabel') }}
        {{ caseReference | caseReferenceDisplay }}
      </p>
    </div>

    <div class="govuk-grid-column-two-thirds">
      {% if documentFolders | length > 0 %}
        {% for folder in documentFolders %}
          {{ folderDocumentsCard(folder, caseReference, submittedOnLabel) }}
        {% endfor %}
      {% else %}
        <p class="govuk-body">{{ t('dashboard:viewDocuments.noDocuments') }}</p>
      {% endif %}
    </div>

    <div class="govuk-grid-column-one-third"></div>
  </div>
{% endblock %}
