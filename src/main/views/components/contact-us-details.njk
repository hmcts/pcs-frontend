{% from "govuk/components/details/macro.njk" import govukDetails %}
 
{% set contactInformation %}
  <h3 class="govuk-heading-s govuk-!-margin-bottom-1">
    {{ t('contactUsDetailsEmailHeading', 'Email') }}
  </h3>

  <p class="govuk-body">
    {{ t('contactUsDetailsEmailIntroPrefix', 'Use the') }}
    <a
      class="govuk-link"
      href="https://www.find-court-tribunal.service.gov.uk/"
      target="_blank"
      rel="noopener noreferrer">
      {{ t(
        'contactUsDetailsEmailLinkText',
        'find a court or tribunal service (opens in new tab)'
      ) }}
    </a>
    {{ t(
      'contactUsDetailsEmailIntroSuffix',
      'to get your local court’s email address.'
    ) }}
  </p>

  <p class="govuk-body">
    {{ t(
      'contactUsDetailsEmailHelp',
      'If you do not know the name of your local court, select the ‘Money’ category and then the ‘Housing’ category to find it.'
    ) }}
  </p>

  <h3 class="govuk-heading-s govuk-!-margin-bottom-1">
    {{ t('contactUsDetailsTelephoneHeading', 'Telephone') }}
  </h3>

  <p class="govuk-body">
    {{ t(
      'contactUsDetailsTelephoneNumber',
      '0300 123 7050<br>Monday to Friday, 8.30am to 5pm.'
    ) }}
  </p>

  <p class="govuk-body">
    <a
      class="govuk-link"
      href="https://www.gov.uk/call-charges"
      target="_blank"
      rel="noopener noreferrer">
      {{ t(
        'contactUsDetailsCallChargesLinkText',
        'Find out about call charges (opens in new tab)'
      ) }}
    </a>
  </p>

{% endset %}

{{ govukDetails({
  summaryText: "Contact us for help",
  html: contactInformation
}) }}