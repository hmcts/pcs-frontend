	                name: "costsMode",
	                fieldset: {
	                  legend: { text: "Costs mode", classes: "govuk-fieldset__legend--s govuk-visually-hidden" }
	                },
	                items: [
	                  {
	                    value: "fixed",
	                    text: "Fixed costs (standard)",
	                    checked: true,
	                    conditional: {
	                      html: govukInput({
	                        label: { text: "Total costs to be paid by Defendant", classes: "govuk-label--s" },
	                        name: "costsFixedAmount",
	                        classes: "govuk-input--width-10 orders-demo__money-input",
	                        prefix: { text: "£" },
	                        value: "424.50"
	                      })
	                    }
	                  },
	                  {
	                    value: "assessed",
	                    text: "Summarily assessed",
	                    conditional: {
	                      html: govukInput({
	                        label: { text: "Assessed costs", classes: "govuk-label--s" },
	                        name: "costsAssessedAmount",
	                        classes: "govuk-input--width-10 orders-demo__money-input",
	                        prefix: { text: "£" },
	                        attributes: { placeholder: "0.00" }
	                      })
	                    }
	                  },
	                  { value: "inTheCase", text: "Costs in the case" },
	                  { value: "reserved", text: "Costs reserved" },
	                  {
	                    value: "other",
	                    text: "Other",
	                    conditional: {
	                      html: govukTextarea({
	                        name: "costsOtherText",
	                        classes: "orders-demo__notes",
	                        rows: 3,
	                        label: { text: "Costs other", classes: "govuk-visually-hidden" }
	                      })
	                    }
	                  },
	                  { value: "silent", text: "[Silent]" }
	                ]
	              }) }}
	            </div>

	            <div class="orders-demo__costs-payby" data-costs-payby>
	              <div class="orders-demo__costs-add-debt" data-costs-same-terms hidden>
	                <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes">
	                  <div class="govuk-checkboxes__item">
	                    <input class="govuk-checkboxes__input" id="costsSuspendedSameTerms" name="costsSuspendedSameTerms" type="checkbox" value="1">
	                    <label class="govuk-label govuk-checkboxes__label" for="costsSuspendedSameTerms">Suspended on same terms</label>
	                  </div>
	                </div>
	              </div>
	              <div class="orders-demo__costs-payby-date" data-payby-date>
	                <label class="govuk-label govuk-label--s orders-demo__costs-payby-label" for="costsPayBy">Pay by</label>
	                {{ govukInput({
	                  id: "costsPayBy",
                  label: { text: "Pay by", classes: "govuk-visually-hidden" },
                  name: "costsPayBy",
                  classes: "govuk-input--width-10 orders-demo__date-input",
                  attributes: { placeholder: "DD/MM/YYYY" }
                }) }}
              </div>
              <div class="orders-demo__costs-add-debt" data-payby-debt hidden>
                <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes">
                  <div class="govuk-checkboxes__item">
                    <input class="govuk-checkboxes__input" id="costsAddToDebt" name="costsAddToDebt" type="checkbox" value="addToDebt" checked>
                    <label class="govuk-label govuk-checkboxes__label" for="costsAddToDebt">Add to judgment debt</label>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="orders-demo__preview" data-preview>
          <button type="button" class="orders-demo__preview-toggle" data-preview-toggle aria-expanded="false">
            <span class="orders-demo__preview-chevron" aria-hidden="true">▶</span>
            <span class="orders-demo__preview-label">Preview draft order</span>
            <span class="orders-demo__preview-status" data-preview-status>Standard order generated</span>
          </button>
          <div class="orders-demo__preview-panel" data-preview-panel hidden>
            <div class="orders-demo__preview-body" data-preview-body>
              <p class="govuk-body">Preview will appear here.</p>
            </div>
            <textarea class="govuk-textarea orders-demo__preview-textarea" name="previewFreeText" rows="12" data-preview-textarea hidden></textarea>
            <div class="orders-demo__preview-actions">
              <div>
                <button type="button" class="govuk-button govuk-button--secondary orders-demo__preview-edit" data-preview-edit>Edit as free text</button>
                <button type="button" class="govuk-link orders-demo__preview-revert" data-preview-revert hidden>Return to generated preview</button>
              </div>
            </div>
          </div>
        </div>
        <div class="orders-demo__footer-actions">
          <button type="button" class="govuk-button orders-demo__preview-submit">Make order</button>
        </div>
      </form>
    </div>
  </main>
</div>
{% endblock %}

{% block footer %}
  {{ govukFooter({}) }}
{% endblock %}

{% block bodyEnd %}
  {{ super() }}
  <script>
    (() => {
      let orderSwitcherInitialised = false;
      let previewLocked = false;

      const getShellRoot = () => {
        const shell = document.querySelector('hmcts-header-shell');
        return shell && (shell.shadowRoot || shell.querySelector('template[shadowrootmode="open"]')?.content);
      };

      const getNavList = () => {
        const root = getShellRoot();
        return root && root.querySelector('.hmcts-primary-navigation__list');
      };

      const ensureMyWorkNav = () => {
        const list = getNavList();
        if (!list) return false;
        const items = Array.from(list.querySelectorAll('.hmcts-primary-navigation__item'));
        const exists = items.some(item => item.textContent && item.textContent.trim().toLowerCase() === 'my work');
        if (!exists) {
          const li = document.createElement('li');
          li.className = 'hmcts-primary-navigation__item';
          const link = document.createElement('a');
          link.className = 'hmcts-primary-navigation__link';
          link.href = '/work';
          const span = document.createElement('span');
          span.className = 'hmcts-primary-navigation__link-text';
          span.textContent = 'My work';
          link.appendChild(span);
          li.appendChild(link);
          list.insertBefore(li, list.firstChild);
        }
        return true;
      };

      const trimNavToCreateCase = () => {
        const list = getNavList();
        if (!list) return false;

        const items = Array.from(list.querySelectorAll('.hmcts-primary-navigation__item'));
        const createCase = items.find(item => /Create case/i.test(item.textContent || ''));
        if (!createCase) return false;

        if (list.firstElementChild !== createCase || list.children.length !== 1) {
          list.innerHTML = '';
          list.appendChild(createCase);
        }
        ensureMyWorkNav();
        return true;
      };

      const setupObserver = () => {
        const list = getNavList();
        if (!list) return false;

        trimNavToCreateCase();
        const observer = new MutationObserver(() => {
          trimNavToCreateCase();
          ensureMyWorkNav();
        });
        observer.observe(list, { childList: true });
        return true;
      };

      const adjustPhaseBannerPadding = () => {
        const root = getShellRoot();
        const phaseText = root && root.querySelector('.govuk-phase-banner__text');
        if (!phaseText) return false;

        phaseText.style.paddingLeft = '0';
        return true;
      };

      const syncArrearsFields = () => {
        const arrearsAtHearing = document.querySelector('input[name="arrearsAtHearing"]');
        const arrearsAmount = document.querySelector('input[name="arrearsAmount"]');
        if (!(arrearsAtHearing instanceof HTMLInputElement) || !(arrearsAmount instanceof HTMLInputElement)) return false;

        const syncValue = () => {
          if (arrearsAmount.dataset.manual === 'true') return;
          arrearsAmount.value = arrearsAtHearing.value;
          if (typeof updatePreview === 'function') {
            updatePreview();
          }
        };

        const markManual = () => {
          arrearsAmount.dataset.manual = 'true';
        };

        syncValue();
        arrearsAtHearing.addEventListener('input', syncValue);
        arrearsAtHearing.addEventListener('change', syncValue);
        arrearsAmount.addEventListener('input', markManual);
        arrearsAmount.addEventListener('change', markManual);
        return true;
      };

      const disableHeaderLinks = () => {
        const root = getShellRoot();
        if (!root) return false;

        root.querySelectorAll('a').forEach(anchor => {
          if (!(anchor instanceof HTMLAnchorElement)) return;
          if (anchor.getAttribute('data-link-disabled') === 'true') return;
          if (!anchor.classList.length) {
            anchor.classList.add('hmcts-header__link');
          }
          anchor.setAttribute('data-link-disabled', 'true');
          anchor.addEventListener('click', event => event.preventDefault());
          anchor.setAttribute('aria-disabled', 'true');
          anchor.setAttribute('tabindex', '-1');
        });
        return true;
      };

      const getInputValue = name => {
        const el = document.querySelector(`[name="${name}"]`);
        if (el instanceof HTMLInputElement || el instanceof HTMLTextAreaElement || el instanceof HTMLSelectElement) {
          return el.value.trim();
        }
        return '';
      };

      const getMoneyValue = (name, fallback = '0.00') => {
        const raw = getInputValue(name);
        const cleaned = raw.replace(/[^0-9.\\-]/g, '');
        const num = Number.parseFloat(cleaned);
        if (Number.isNaN(num)) return fallback;
        return num.toFixed(2);
      };

	      const getDateString = prefix => {
	        const day = getInputValue(`${prefix}-day`).padStart(2, '0');
	        const month = getInputValue(`${prefix}-month`).padStart(2, '0');
	        const year = getInputValue(`${prefix}-year`);
	        if (!day || !month || !year) return '';
	        return `${day}/${month}/${year}`;
	      };

	      const getCheckedValues = name =>
	        Array.from(document.querySelectorAll(`input[name="${name}"]:checked`))
	          .map(el => (el instanceof HTMLInputElement ? el.value : ''))
	          .filter(Boolean);

	      const initOrderSwitcher = () => {
	        if (orderSwitcherInitialised) return;

        const sections = Array.from(document.querySelectorAll('.orders-demo__order-section'));
        if (!sections.length) return;

        orderSwitcherInitialised = true;

        const offsetDate = offset => {
          const date = new Date();
          date.setDate(date.getDate() + offset);
          return {
            day: String(date.getDate()).padStart(2, '0'),
            month: String(date.getMonth() + 1).padStart(2, '0'),
            year: String(date.getFullYear())
          };
        };

        const setDefaultDate = (groupName, offsetDays = 14) => {
          const dayInput = document.querySelector(`input[name="${groupName}-day"]`);
          const monthInput = document.querySelector(`input[name="${groupName}-month"]`);
          const yearInput = document.querySelector(`input[name="${groupName}-year"]`);
          if (!dayInput || !monthInput || !yearInput) return;

          if (dayInput.value || monthInput.value || yearInput.value) return;

          const { day, month, year } = offsetDate(offsetDays);
          dayInput.value = day;
          monthInput.value = month;
          yearInput.value = year;
        };

        const initDateShortcuts = () => {
          const groups = Array.from(document.querySelectorAll('.orders-demo__date-inline--with-buttons'));
          groups.forEach(group => {
            const dayInput = group.querySelector('input[name$="-day"]');
            const monthInput = group.querySelector('input[name$="-month"]');
            const yearInput = group.querySelector('input[name$="-year"]');
            if (!dayInput || !monthInput || !yearInput) return;

            group.querySelectorAll('.orders-demo__date-shortcut').forEach(button => {
              const offset = Number(button.dataset.offset || 0);
              button.addEventListener('click', () => {
                const { day, month, year } = offsetDate(offset);
                dayInput.value = day;
                monthInput.value = month;
                yearInput.value = year;
                updatePreview();
              });
            });
          });
        };

        const focusInstalmentAmount = () => {
          const instalmentInput = document.querySelector('input[name="instalmentAmount"]');
          if (instalmentInput instanceof HTMLInputElement) {
            instalmentInput.focus();
          }
        };

	        const focusAdjournDate = () => {
	          const mode = document.querySelector('input[name="adjournNextHearingMode"]:checked')?.value;
	          const prefix = mode === 'onDate' ? 'adjournOnDate' : 'adjournFirstAvailableAfter';
	          const adjournDay = document.querySelector(`input[name="${prefix}-day"]`);
	          if (adjournDay instanceof HTMLInputElement) {
	            adjournDay.focus();
	          }
	        };

        const formatDate = ({ day, month, year }) => `${day}/${month}/${year}`;

	        const initStandardDirections = () => {
	          const button = document.querySelector('.orders-demo__adjourn-insert');
	          const textarea = document.querySelector('textarea[name="adjournDirections"]');
	          if (!button || !textarea) return;

	          button.addEventListener('click', () => {
	            const line1 = `1. The Defendant shall file and serve a Defence and any Counterclaim by 4pm on ${formatDate(offsetDate(14))}.`;
	            const line2 = `2. The Claimant shall file and serve a Reply by 4pm on ${formatDate(offsetDate(28))}.`;
	            textarea.value = `${line1}\n${line2}`;
	            textarea.focus();
	            updatePreview();
	          });
	        };

	        const buildCostsLine = (mode, payByText) => {
	          const fixedAmount = getMoneyValue('costsFixedAmount', '424.50');
	          const assessedAmount = getMoneyValue('costsAssessedAmount', '');
	          const otherText = getInputValue('costsOtherText');
	          const sameTerms = (() => {
	            const checkbox = document.getElementById('costsSuspendedSameTerms');
	            const wrapper = checkbox instanceof HTMLInputElement ? checkbox.closest('[data-costs-same-terms]') : null;
	            return checkbox instanceof HTMLInputElement && !wrapper?.hidden && checkbox.checked;
	          })();
	          const sameTermsSuffix = sameTerms ? ' This order for costs is suspended on the same terms.' : '';

	          if (mode === 'silent') return '';
	          if (mode === 'inTheCase') return `Costs in the case.${sameTermsSuffix}`;
	          if (mode === 'reserved') return `The costs of this hearing are reserved.${sameTermsSuffix}`;
	          if (mode === 'other') {
	            if (!otherText) return `Costs.${sameTermsSuffix}`;
	            return `${otherText}${sameTermsSuffix}`;
	          }
	          if (mode === 'fixed') {
	            return `The Defendant shall pay the Claimant's costs of this claim summarily assessed in the sum of £${fixedAmount}${payByText ? ` by ${payByText}` : ''}.${sameTermsSuffix}`;
	          }
	          if (mode === 'assessed') {
	            if (!assessedAmount) return `The Defendant shall pay the Claimant's costs of this claim, summarily assessed.${sameTermsSuffix}`;
	            return `The Defendant shall pay the Claimant's costs of this claim summarily assessed in the sum of £${assessedAmount}${payByText ? ` by ${payByText}` : ''}.${sameTermsSuffix}`;
	          }
	          return '';
	        };

        const buildPreview = () => {
          const orderType = document.querySelector('input[name="orderType"]:checked')?.value || 'outright';
          const possessionDate = orderType === 'suspended'
            ? getDateString('suspendedBy') || getDateString('outrightBy')
            : getDateString('outrightBy') || getDateString('suspendedBy');
	          const arrears = getMoneyValue('arrearsAmount', getMoneyValue('arrearsAtHearing', '0.00'));
	          const rent = getMoneyValue('currentRent', '0.00');
	          const instalment = getMoneyValue('instalmentAmount', '0.00');
	          const instalmentFreq = getInputValue('instalmentFrequency') || 'month';
	          const instalmentFreqText =
	            instalmentFreq === 'other' ? (getInputValue('instalmentFrequencyOther') || '[period]') : instalmentFreq;
	          const address = '12 High Street, Bristol';
          const costsMode = document.querySelector('input[name="costsMode"]:checked')?.value || 'fixed';
          const payByCheckbox = document.getElementById('costsAddToDebt');
          const payByText = (() => {
            const addDebt = payByCheckbox instanceof HTMLInputElement && !payByCheckbox.closest('[data-payby-debt]')?.hidden && payByCheckbox.checked;
            if (addDebt) return 'being added to the judgment debt';
            return getInputValue('costsPayBy');
          })();

          const moneyToNumber = val => {
            const num = Number.parseFloat(val);
            return Number.isNaN(num) ? 0 : num;
          };

          const lines = [];
          let status = 'Draft order generated';

	          if (orderType === 'adjourn') {
	            const adjournmentMode = document.querySelector('input[name="adjournmentMode"]:checked')?.value || 'nextHearing';
	            const estimate = getInputValue('adjournTimeEstimate');
	            const directions = getInputValue('adjournDirections');

	            lines.push('IT IS ORDERED THAT:');
	            if (adjournmentMode === 'generally') {
	              lines.push('1. The claim is adjourned generally with permission to restore.');
	              let number = 2;

	              const paymentEnabled = document.getElementById('adjournGenerallyPaymentEnabled');
	              if (paymentEnabled instanceof HTMLInputElement && paymentEnabled.checked) {
	                const amount = getMoneyValue('adjournGenerallyPaymentAmount', '') || '[amount]';
	                const freq = getInputValue('adjournGenerallyPaymentFrequency') || 'month';
	                const freqText = freq === 'other' ? (getInputValue('adjournGenerallyPaymentFrequencyOther') || '[period]') : freq;
	                const firstPaymentBy = getInputValue('adjournGenerallyFirstPaymentBy') || '[date]';
	                lines.push(`${number}. On payment of current rent plus £${amount} per ${freqText}, first payment by ${firstPaymentBy}.`);
	                number += 1;
	              }

	              const strikeOutEnabled = document.getElementById('adjournGenerallyStrikeOutEnabled');
	              if (strikeOutEnabled instanceof HTMLInputElement && strikeOutEnabled.checked) {
	                const strikeOutBy = getInputValue('adjournGenerallyStrikeOutBy') || '[date]';
	                lines.push(`${number}. And the claim will stand struck out if no application is received by HMCTS by 4pm on ${strikeOutBy}.`);
	                number += 1;
	              }

	              const costsLine = buildCostsLine(costsMode, payByText);
	              if (costsLine) lines.push(`${number}. ${costsLine}`);
	            } else {
	              const hearingMode =
	                document.querySelector('input[name="adjournNextHearingMode"]:checked')?.value || 'firstAvailableAfter';
	              const hearingDate =
	                hearingMode === 'onDate' ? getDateString('adjournOnDate') : getDateString('adjournFirstAvailableAfter');
	              const dateText = hearingDate || '[date]';
	              const estimateText = estimate ? ` with a time estimate of ${estimate}` : '';
	              const hearingText =
	                hearingMode === 'onDate'
	                  ? `The claim is adjourned to ${dateText}${estimateText}.`
	                  : `The claim is adjourned to the first available date after ${dateText}${estimateText}.`;

	              lines.push(`1. ${hearingText}`);
	              let number = 2;
	              if (directions) {
	                lines.push(`${number}. ${directions}`);
	                number += 1;
	              }
	              const costsLine = buildCostsLine(costsMode, payByText);
	              if (costsLine) lines.push(`${number}. ${costsLine}`);
	            }
	            status = 'Adjournment draft generated';
	          } else if (orderType === 'dismissed') {
	            const outcome = document.querySelector('input[name="dismissalOutcome"]:checked')?.value || 'dismissed';
	            lines.push('IT IS ORDERED THAT:');
	            lines.push(`1. The claim is ${outcome === 'struckOut' ? 'struck out' : 'dismissed'}.`);
	            const costsLine = buildCostsLine(costsMode, payByText);
	            if (costsLine) lines.push(`2. ${costsLine}`);
	            status = 'Outcome draft generated';
	          } else if (orderType === 'suspended') {
	            const costsAmount = costsMode === 'fixed'
	              ? getMoneyValue('costsFixedAmount', '424.50')
	              : costsMode === 'assessed'
	                  ? getMoneyValue('costsAssessedAmount', '0.00')
	                  : '0.00';
	            const total = (moneyToNumber(arrears) + moneyToNumber(costsAmount)).toFixed(2);
	            lines.push('Upon hearing the Solicitor for the Claimant and the Defendant in Person.');
	            lines.push('IT IS ORDERED THAT:');
	            lines.push(`1. The Defendant give the Claimant possession of ${address} on or before ${possessionDate || '[date]'}.`);
	            lines.push(`2. This order is not to be enforced so long as the Defendant pays the Claimant the current rent of £${rent} per ${instalmentFreqText}, plus £${instalment} per ${instalmentFreqText} towards the arrears.`);
	            lines.push(`3. The first payment to be made on or before ${possessionDate || '[date]'}.`);
	            const costsLine = buildCostsLine(costsMode, payByText);
	            if (costsLine) lines.push(`4. ${costsLine}`);
	            lines.push(`5. The Defendant pay the Claimant the total sum of £${total}.`);
	            status = 'Suspended order draft generated';
	          } else {
	            const costsAmount = costsMode === 'fixed'
	              ? getMoneyValue('costsFixedAmount', '424.50')
	              : costsMode === 'assessed'
	                  ? getMoneyValue('costsAssessedAmount', '0.00')
	                  : '0.00';
	            const total = (moneyToNumber(arrears) + moneyToNumber(costsAmount)).toFixed(2);
	            lines.push('Upon hearing the Solicitor for the Claimant and the Defendant in Person.');
	            lines.push('IT IS ORDERED THAT:');
	            lines.push(`1. The Defendant give the Claimant possession of ${address} on or before ${possessionDate || '[date]'}.`);
	            if (moneyToNumber(costsAmount) > 0) {
	              lines.push(`2. The Defendant pay the Claimant the total sum of £${total} (comprising arrears of £${arrears} and costs of £${costsAmount})${payByText ? ` by ${payByText}` : ''}.`);
	            } else {
	              lines.push(`2. The Defendant pay the Claimant arrears of £${arrears}${payByText ? ` by ${payByText}` : ''}.`);
	            }
	            const costsLine = buildCostsLine(costsMode, payByText);
	            if (costsLine && costsMode !== 'fixed') lines.push(`3. ${costsLine}`);
	            status = 'Outright order draft generated';
	          }

	          const judgmentToggle = document.getElementById('judgmentEnabled');
	          const judgmentEnabled = judgmentToggle instanceof HTMLInputElement && judgmentToggle.checked;
	          if (judgmentEnabled) {
	            const judgmentLines = [];
	            const against = getCheckedValues('judgmentDefendants');
	            const againstText = against.length ? against.join(', ') : 'the Defendant';

	            const heads = [];
	            const arrearsEnabled = document.getElementById('judgmentArrearsEnabled');
	            if (arrearsEnabled instanceof HTMLInputElement && arrearsEnabled.checked) {
	              const amount = getMoneyValue('judgmentArrearsAmount', '') || '[amount]';
	              heads.push(`arrears of £${amount}`);
	            }
	            const interestEnabled = document.getElementById('judgmentInterestEnabled');
	            if (interestEnabled instanceof HTMLInputElement && interestEnabled.checked) {
	              const amount = getMoneyValue('judgmentInterestAmount', '') || '[amount]';
	              heads.push(`interest of £${amount}`);
	            }
	            const uoEnabled = document.getElementById('judgmentUseOccupationEnabled');
	            if (uoEnabled instanceof HTMLInputElement && uoEnabled.checked) {
	              const rate = getMoneyValue('judgmentUseOccupationDailyRate', '') || '[amount]';
	              const from = getInputValue('judgmentUseOccupationFrom') || '[date]';
	              heads.push(`use and occupation at a daily rate of £${rate} from ${from} until possession is given up`);
	            }

	            const terms = [];
	            const sameTermsEnabled = document.getElementById('judgmentSuspendedSameTerms');
	            if (orderType === 'suspended' && sameTermsEnabled instanceof HTMLInputElement && sameTermsEnabled.checked) {
	              terms.push('suspended on the same terms');
	            }

	            const instalmentsEnabled = document.getElementById('judgmentInstalmentsEnabled');
	            if (instalmentsEnabled instanceof HTMLInputElement && instalmentsEnabled.checked) {
	              const amount = getMoneyValue('judgmentInstalmentsAmount', '') || '[amount]';
	              const frequency = getInputValue('judgmentInstalmentsFrequency') || 'month';
	              const frequencyText =
	                frequency === 'other' ? (getInputValue('judgmentInstalmentsFrequencyOther') || '[period]') : frequency;
	              const firstBy = getInputValue('judgmentInstalmentsFirstPaymentBy') || '[date]';
	              terms.push(`by instalments of £${amount} per ${frequencyText}, first payment by ${firstBy}`);
	            }

	            judgmentLines.push('JUDGMENT');
	            judgmentLines.push(`Judgment against ${againstText}${heads.length ? ' for:' : '.'}`);
	            heads.forEach(item => judgmentLines.push(`- ${item}`));
	            if (terms.length) {
	              judgmentLines.push('And such judgment is:');
	              terms.forEach(item => judgmentLines.push(`- ${item}`));
	            }
	            lines.push(judgmentLines.join('\n'));
	          }

	          return { text: lines.join('\n\n'), status };
	        };

        const initPreview = () => {
          const toggle = document.querySelector('[data-preview-toggle]');
          const panel = document.querySelector('[data-preview-panel]');
          const chevron = document.querySelector('.orders-demo__preview-chevron');
          const body = document.querySelector('[data-preview-body]');
          const textarea = document.querySelector('[data-preview-textarea]');
          const edit = document.querySelector('[data-preview-edit]');
          const revert = document.querySelector('[data-preview-revert]');
          const statusEl = document.querySelector('[data-preview-status]');
          if (!toggle || !panel || !body || !textarea || !edit || !statusEl) return;

          const setExpanded = expanded => {
            panel.hidden = !expanded;
            toggle.setAttribute('aria-expanded', expanded ? 'true' : 'false');
            if (chevron) {
              chevron.style.transform = expanded ? 'rotate(90deg)' : 'rotate(0deg)';
            }
            if (expanded && !previewLocked) {
              const { text, status } = buildPreview();
              body.textContent = text;
              statusEl.textContent = status;
            }
          };

          toggle.addEventListener('click', () => setExpanded(panel.hidden));

          edit.addEventListener('click', () => {
            const { text } = buildPreview();
            body.hidden = true;
            textarea.hidden = false;
            textarea.value = text;
            previewLocked = true;
            if (revert) revert.hidden = false;
            textarea.focus();
          });

          if (revert) {
            revert.addEventListener('click', () => {
              previewLocked = false;
              textarea.hidden = true;
              body.hidden = false;
              revert.hidden = true;
              const { text, status } = buildPreview();
              body.textContent = text;
              statusEl.textContent = status;
            });
          }

          const { text, status } = buildPreview();
          body.textContent = text;
          statusEl.textContent = status;
        };

        const updatePreview = () => {
          if (previewLocked) return;
          const body = document.querySelector('[data-preview-body]');
          const statusEl = document.querySelector('[data-preview-status]');
          if (!body || !statusEl) return;
          const { text, status } = buildPreview();
          body.textContent = text;
          statusEl.textContent = status;
        };

        const initOrderClickTargets = () => {
          sections.forEach(section => {
            const radio = section.querySelector('input[name="orderType"]');
            if (!radio) return;

            section.addEventListener('click', event => {
              const target = event.target;
              if (!(target instanceof HTMLElement)) return;

              const isFormControl = target.closest('input, select, textarea, button');
              if (isFormControl && !(isFormControl instanceof HTMLInputElement && isFormControl.type === 'radio')) {
                return;
              }
              if (!radio.checked) {
                radio.checked = true;
                setActive(radio.value);
              }
            });
          });
        };

	        const applyCostsModeDefaults = mode => {
	          if (mode === 'fixed') {
	            const fixed = document.querySelector('input[name="costsFixedAmount"]');
	            if (fixed instanceof HTMLInputElement && !fixed.value) {
	              fixed.value = '424.50';
	            }
	          }
	          if (mode === 'assessed') {
	            const assessed = document.querySelector('input[name="costsAssessedAmount"]');
	            if (assessed instanceof HTMLInputElement) {
	              assessed.value = '';
	              assessed.focus();
	            }
	          }
	          if (mode === 'other') {
	            const textarea = document.querySelector('textarea[name="costsOtherText"]');
	            if (textarea instanceof HTMLTextAreaElement) {
	              textarea.focus();
	            }
	          }
	        };

	        const setCostsMode = mode => {
	          const radio = document.querySelector(`input[name="costsMode"][value="${mode}"]`);
	          if (!(radio instanceof HTMLInputElement)) return;
	          radio.checked = true;
	          radio.dispatchEvent(new Event('change', { bubbles: true }));
	          applyCostsModeDefaults(mode);
	        };

	        const updateCostsSameTermsVisibility = orderType => {
	          const wrapper = document.querySelector('[data-costs-same-terms]');
	          const checkbox = document.getElementById('costsSuspendedSameTerms');
	          if (!wrapper || !(checkbox instanceof HTMLInputElement)) return;

	          const hasPaymentTerms = (() => {
	            if (orderType === 'suspended') {
	              const arrears = document.getElementById('arrearsCheckbox');
	              const initial = document.getElementById('initialPaymentCheckbox');
	              const instalments = document.getElementById('instalmentCheckbox');
	              return (
	                (arrears instanceof HTMLInputElement && arrears.checked) ||
	                (initial instanceof HTMLInputElement && initial.checked) ||
	                (instalments instanceof HTMLInputElement && instalments.checked)
	              );
	            }

	            if (orderType === 'adjourn') {
	              const adjMode = document.querySelector('input[name="adjournmentMode"]:checked')?.value;
	              if (adjMode !== 'generally') return false;
	              const enabled = document.getElementById('adjournGenerallyPaymentEnabled');
	              if (!(enabled instanceof HTMLInputElement) || !enabled.checked) return false;
	              return Boolean(getInputValue('adjournGenerallyPaymentAmount'));
	            }

	            return false;
	          })();

	          wrapper.hidden = !hasPaymentTerms;
	          if (!hasPaymentTerms) checkbox.checked = false;
	        };

	        const setCostsPayBy = orderType => {
	          const payByWrapper = document.querySelector('[data-costs-payby]');
	          const payByDate = document.querySelector('[data-payby-date]');
	          const payByInput = document.getElementById('costsPayBy');
          const addToDebt = document.querySelector('[data-payby-debt]');
          const debtCheckbox = document.getElementById('costsAddToDebt');

          if (!payByWrapper || !payByDate || !(payByInput instanceof HTMLInputElement) || !addToDebt) return;

	          const showDebt = orderType === 'suspended';
	          addToDebt.hidden = !showDebt;
	          payByDate.hidden = showDebt;
	          if (showDebt) {
	            if (debtCheckbox instanceof HTMLInputElement) debtCheckbox.checked = true;
	            updateCostsSameTermsVisibility(orderType);
	            updatePreview();
	            return;
	          }

          const group = orderType === 'suspended' ? 'suspendedBy' : 'outrightBy';
          const dayInput = document.querySelector(`input[name="${group}-day"]`);
          const monthInput = document.querySelector(`input[name="${group}-month"]`);
          const yearInput = document.querySelector(`input[name="${group}-year"]`);
          const hasDate = dayInput?.value && monthInput?.value && yearInput?.value;
          const { day, month, year } = hasDate
            ? { day: dayInput.value.padStart(2, '0'), month: monthInput.value.padStart(2, '0'), year: yearInput.value }
            : offsetDate(14);
	          payByInput.value = `${day}/${month}/${year}`;
	          updateCostsSameTermsVisibility(orderType);
	          updatePreview();
	        };

	        const initCostsRadios = () => {
	          const radios = Array.from(document.querySelectorAll('input[name="costsMode"]'));
	          radios.forEach(radio => {
	            radio.addEventListener('change', () => applyCostsModeDefaults(radio.value));
	            radio.addEventListener('change', updatePreview);
	          });
	        };

	        const initJudgmentSection = () => {
	          const enabled = document.getElementById('judgmentEnabled');
	          const body = document.querySelector('[data-judgment-body]');
	          if (!(enabled instanceof HTMLInputElement) || !body) return;

	          const apply = () => {
	            body.hidden = !enabled.checked;
	            updatePreview();
	          };

	          enabled.addEventListener('change', apply);
	          apply();
	        };

	        const setJudgmentSameTermsVisibility = orderType => {
	          const wrapper = document.querySelector('[data-judgment-same-terms]');
	          if (!wrapper) return;
	          const shouldShow = orderType === 'suspended';
	          wrapper.hidden = !shouldShow;

	          if (!shouldShow) {
	            const checkbox = wrapper.querySelector('input[type="checkbox"]');
	            if (checkbox instanceof HTMLInputElement) checkbox.checked = false;
	          }
	        };

	        const initJudgmentInstalmentFrequency = () => {
	          const select = document.getElementById('judgmentInstalmentsFrequency');
	          const otherWrapper = document.querySelector('[data-judgment-instalments-other]');
	          const otherInput = document.getElementById('judgmentInstalmentsFrequencyOther');
	          if (!(select instanceof HTMLSelectElement) || !otherWrapper || !(otherInput instanceof HTMLInputElement)) return;

	          const apply = () => {
	            const isOther = select.value === 'other';
	            otherWrapper.hidden = !isOther;
	            if (!isOther) otherInput.value = '';
	          };

	          select.addEventListener('change', () => {
	            apply();
	            updatePreview();
	          });
	          apply();
	        };

	        const initSuspendedInstalmentFrequency = () => {
	          const select = document.getElementById('instalmentFrequency');
	          const otherWrapper = document.querySelector('[data-instalment-frequency-other]');
	          const otherInput = document.getElementById('instalmentFrequencyOther');
	          if (!(select instanceof HTMLSelectElement) || !otherWrapper || !(otherInput instanceof HTMLInputElement)) return;

	          const apply = () => {
	            const isOther = select.value === 'other';
	            otherWrapper.hidden = !isOther;
	            if (!isOther) otherInput.value = '';
	          };

	          select.addEventListener('change', () => {
	            apply();
	            updatePreview();
	          });
	          apply();
	        };

	        const initAdjournmentMode = () => {
	          const nextHearing = document.querySelector('[data-adjourn-next-hearing]');
	          const generally = document.querySelector('[data-adjourn-generally]');
	          const radios = Array.from(document.querySelectorAll('input[name="adjournmentMode"]'));
	          if (!nextHearing || !generally || !radios.length) return;

	          const apply = () => {
	            const mode = document.querySelector('input[name="adjournmentMode"]:checked')?.value || 'nextHearing';
	            const isGenerally = mode === 'generally';
	            nextHearing.hidden = isGenerally;
	            generally.hidden = !isGenerally;
	            updatePreview();
	          };

	          radios.forEach(radio => radio.addEventListener('change', apply));
	          apply();
	        };

	        const initAdjournGenerallyFrequency = () => {
	          const select = document.getElementById('adjournGenerallyPaymentFrequency');
	          const otherWrapper = document.querySelector('[data-adjourn-generally-frequency-other]');
	          const otherInput = document.getElementById('adjournGenerallyPaymentFrequencyOther');
	          if (!(select instanceof HTMLSelectElement) || !otherWrapper || !(otherInput instanceof HTMLInputElement)) return;

	          const apply = () => {
	            const isOther = select.value === 'other';
	            otherWrapper.hidden = !isOther;
	            if (!isOther) otherInput.value = '';
	          };

	          select.addEventListener('change', () => {
	            apply();
	            updatePreview();
	          });
	          apply();
	        };

	        const setActive = value => {
	          sections.forEach(section => {
	            const isActive = section.dataset.orderType === value;
	            section.classList.toggle('orders-demo__order-section--active', isActive);
	            section.classList.toggle('orders-demo__order-section--inactive', !isActive);
	          });

	          if (value === 'suspended') {
	            focusInstalmentAmount();
	            setCostsMode('fixed');
	          } else if (value === 'adjourn') {
	            focusAdjournDate();
	            setCostsMode('reserved');
	          } else if (value === 'outright') {
	            setCostsMode('fixed');
	          } else {
	            setCostsMode('silent');
	          }

	          setCostsPayBy(value);
	          setJudgmentSameTermsVisibility(value);
	          updateCostsSameTermsVisibility(value);
	          updatePreview();
	        };

        const defaultValue = document.querySelector('input[name="orderType"]:checked')?.value
          || sections[0]?.dataset.orderType;

        sections.forEach(section => {
          const radio = section.querySelector('input[name="orderType"]');
          if (!radio) return;
          radio.addEventListener('change', () => setActive(radio.value));
        });

	        setActive(defaultValue);
	        setDefaultDate('outrightBy');
	        setDefaultDate('suspendedBy');
	        initDateShortcuts();
	        initOrderClickTargets();
	        initStandardDirections();
	        initCostsRadios();
	        initJudgmentSection();
	        initJudgmentInstalmentFrequency();
	        initSuspendedInstalmentFrequency();
	        initAdjournmentMode();
	        initAdjournGenerallyFrequency();
	        initPreview();

        const form = document.querySelector('.orders-demo__form');
        const generatedPreviewInput = document.querySelector('input[name="generatedPreviewText"]');
        const generatedPreviewStatusInput = document.querySelector('input[name="generatedPreviewStatus"]');
	        if (form) {
	          const handleChange = () => {
	            const selectedOrderType = document.querySelector('input[name="orderType"]:checked')?.value || defaultValue;
	            updateCostsSameTermsVisibility(selectedOrderType);
	            updatePreview();
	          };
	          form.addEventListener('input', handleChange);
	          form.addEventListener('change', handleChange);
	          form.addEventListener('submit', event => {
	            event.preventDefault();
	            const { text, status } = buildPreview();
            const freeText = document.querySelector('[data-preview-textarea]');
            const editedText =
              freeText instanceof HTMLTextAreaElement && !freeText.hidden && freeText.value ? freeText.value : '';

            if (generatedPreviewInput instanceof HTMLInputElement) {
              generatedPreviewInput.value = editedText || text;
            }
            if (generatedPreviewStatusInput instanceof HTMLInputElement) {
              generatedPreviewStatusInput.value = status || '';
            }
          });
        }
      };

      const start = () => {
        adjustPhaseBannerPadding();
        initOrderSwitcher();
        ensureMyWorkNav();
        syncArrearsFields();
        disableHeaderLinks();
        if (setupObserver()) return;

        let attempts = 0;
        const interval = setInterval(() => {
          const observerReady = setupObserver();
          adjustPhaseBannerPadding();
          initOrderSwitcher();
          ensureMyWorkNav();
          disableHeaderLinks();
          if (observerReady || attempts >= 50) {
            clearInterval(interval);
          }
          attempts += 1;
        }, 200);
      };

      if (document.readyState === 'complete' || document.readyState === 'interactive') {
        start();
      } else {
        document.addEventListener('DOMContentLoaded', start);
      }
    })();
  </script>
{% endblock %}
