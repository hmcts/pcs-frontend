{% extends "template.njk" %}
{% from "govuk/components/footer/macro.njk" import govukFooter %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/textarea/macro.njk" import govukTextarea %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/date-input/macro.njk" import govukDateInput %}
{% from "govuk/components/checkboxes/macro.njk" import govukCheckboxes %}

{% block head %}
  {{ super() }}
  <script type="module" src="{{ headerShell.assets.scripts[0] }}"></script>
{% endblock %}

{% block header %}
  {{ headerShell.html | safe }}
{% endblock %}

{% block content %}
<div class="govuk-width-container orders-demo">
  <main class="govuk-main-wrapper orders-demo__main" id="content" role="main">
    <div class="orders-demo__panel">
      <form class="orders-demo__form" action="#" method="post" novalidate>
        <div class="orders-demo__top-grid orders-demo__top-grid--sticky">
          <div class="orders-demo__summary">
            <p class="govuk-caption-l govuk-!-margin-bottom-1">Case</p>
            <h1 class="govuk-heading-l govuk-!-margin-bottom-1">Make an order</h1>
            <p class="govuk-body govuk-!-margin-bottom-1 govuk-!-font-weight-bold">{{ caseReference | default('1234-5678-9101') }}</p>
            <p class="govuk-body govuk-!-margin-bottom-4">{{ caseTitle | default('Smith v Jones') }}</p>
          </div>

          <div class="orders-demo__judicial">
            <div class="orders-demo__section-header">
              <h2 class="govuk-heading-m govuk-!-margin-bottom-1">Judicial Notes (Tenancy)</h2>
              <p class="govuk-body-s govuk-!-margin-bottom-3">
                Last updated {{ lastUpdated | default('25/10/2025') }} by {{ lastUpdatedBy | default('DJ Daley') }}
              </p>
            </div>

            <div class="orders-demo__input-grid">
              {{ govukInput({
                label: { text: "Date of tenancy", classes: "govuk-label--s" },
                classes: "govuk-input--width-10",
                name: "dateOfTenancy",
                value: dateOfTenancy | default('01/05/2020'),
                attributes: { placeholder: "DD/MM/YYYY" }
              }) }}
              {{ govukInput({
                label: { text: "Date notice s/vd", classes: "govuk-label--s" },
                classes: "govuk-input--width-10",
                name: "dateNotice",
                value: dateNoticeServed | default('15/09/2024'),
                attributes: { placeholder: "DD/MM/YYYY" }
              }) }}
              {{ govukInput({
                label: { text: "Grounds", classes: "govuk-label--s" },
                name: "grounds",
                classes: "govuk-input--width-20",
                value: grounds | default('8, 10, 11'),
                attributes: { placeholder: "eg 8, 10, 11 or NTQ" }
              }) }}
              {{ govukInput({
                label: { text: "Arrears on issue", classes: "govuk-label--s" },
                classes: "govuk-input--width-10",
                name: "arrearsOnIssue",
                value: arrearsOnIssue | default('825.00'),
                prefix: { text: "£" },
                attributes: { placeholder: "0.00" }
              }) }}
            </div>

            <div class="orders-demo__input-grid">
              {{ govukInput({
                label: { text: "Arrears at notice", classes: "govuk-label--s" },
                classes: "govuk-input--width-10",
                name: "arrearsAtNotice",
                value: arrearsAtNotice | default('1100.00'),
                prefix: { text: "£" },
                attributes: { placeholder: "0.00" }
              }) }}
              {{ govukInput({
                label: { text: "Arrears at hearing", classes: "govuk-label--s" },
                classes: "govuk-input--width-10",
                name: "arrearsAtHearing",
                value: arrearsAtHearing | default('1250.00'),
                prefix: { text: "£" },
                attributes: { placeholder: "0.00" }
              }) }}
              {{ govukInput({
                label: { text: "Current rent", classes: "govuk-label--s" },
                classes: "govuk-input--width-10 orders-demo__rent-input",
                name: "currentRent",
                value: currentRent | default('550.00'),
                prefix: { text: "£" },
                attributes: { placeholder: "0.00" }
              }) }}
              {% set rentFrequency = currentRentFrequency | default('month') %}
              <div class="orders-demo__rent-frequency">
                <label class="govuk-label govuk-label--s" for="currentRentFrequency">per</label>
                <select class="govuk-select" id="currentRentFrequency" name="currentRentFrequency">
                  <option value="month" {{ 'selected' if rentFrequency == 'month' }}>month</option>
                  <option value="quarter" {{ 'selected' if rentFrequency == 'quarter' }}>quarter</option>
                  <option value="year" {{ 'selected' if rentFrequency == 'year' }}>year</option>
                </select>
              </div>
            </div>
          </div>

          <div class="orders-demo__hearing">
            <div class="orders-demo__section-header">
              <h2 class="govuk-heading-m govuk-!-margin-bottom-2">Hearing Notes</h2>
            </div>
            {{ govukTextarea({
              name: "hearingNotes",
              classes: "orders-demo__notes",
              rows: 7,
              label: { text: "Add notes for the bench", classes: "govuk-visually-hidden" },
              hint: { text: "" }
            }) }}
          </div>
        </div>

        <div class="orders-demo__section orders-demo__participants">
          <h2 class="govuk-heading-m govuk-!-margin-bottom-3">Attendance</h2>
          <table class="govuk-table orders-demo__party-table">
            <thead class="govuk-table__head">
              <tr class="govuk-table__row">
                <th scope="col" class="govuk-table__header govuk-!-width-one-quarter">Party</th>
                <th scope="col" class="govuk-table__header">LIP</th>
                <th scope="col" class="govuk-table__header">Csl</th>
                <th scope="col" class="govuk-table__header">Sol</th>
                <th scope="col" class="govuk-table__header">S/A</th>
                <th scope="col" class="govuk-table__header">H/O Rep</th>
                <th scope="col" class="govuk-table__header">Not present</th>
              </tr>
            </thead>
            <tbody class="govuk-table__body">
              <tr class="govuk-table__row">
                <th scope="row" class="govuk-table__header">Claimant ({{ claimantName | default('Smith') }})</th>
                <td class="govuk-table__cell orders-demo__party-cell">
                  <div class="govuk-radios govuk-radios--inline orders-demo__radios-inline">
                    <div class="govuk-radios__item">
                      <input class="govuk-radios__input" id="claimant-lip" name="claimantAttendance" type="radio" value="lip" checked>
                      <label class="govuk-label govuk-radios__label" for="claimant-lip">
                        <span class="govuk-visually-hidden">Claimant</span>
                      </label>
                    </div>
                  </div>
                </td>
                <td class="govuk-table__cell orders-demo__party-cell">
                  <div class="govuk-radios govuk-radios--inline orders-demo__radios-inline">
                    <div class="govuk-radios__item">
                      <input class="govuk-radios__input" id="claimant-counsel" name="claimantAttendance" type="radio" value="counsel">
                      <label class="govuk-label govuk-radios__label" for="claimant-counsel">
                        <span class="govuk-visually-hidden">Claimant</span>
                      </label>
                    </div>
                  </div>
                </td>
                <td class="govuk-table__cell orders-demo__party-cell">
                  <div class="govuk-radios govuk-radios--inline orders-demo__radios-inline">
                    <div class="govuk-radios__item">
                      <input class="govuk-radios__input" id="claimant-solicitor" name="claimantAttendance" type="radio" value="solicitor">
                      <label class="govuk-label govuk-radios__label" for="claimant-solicitor">
                        <span class="govuk-visually-hidden">Claimant</span>
                      </label>
                    </div>
                  </div>
                </td>
                <td class="govuk-table__cell orders-demo__party-cell">
                  <div class="govuk-radios govuk-radios--inline orders-demo__radios-inline">
                    <div class="govuk-radios__item">
                      <input class="govuk-radios__input" id="claimant-agent" name="claimantAttendance" type="radio" value="solicitorAgent">
                      <label class="govuk-label govuk-radios__label" for="claimant-agent">
                        <span class="govuk-visually-hidden">Claimant</span>
                      </label>
                    </div>
                  </div>
                </td>
                <td class="govuk-table__cell orders-demo__party-cell">
                  <div class="govuk-radios govuk-radios--inline orders-demo__radios-inline">
                    <div class="govuk-radios__item">
                      <input class="govuk-radios__input" id="claimant-ho-rep" name="claimantAttendance" type="radio" value="housingOfficerRep">
                      <label class="govuk-label govuk-radios__label" for="claimant-ho-rep">
                        <span class="govuk-visually-hidden">Claimant</span>
                      </label>
                    </div>
                  </div>
                </td>
                <td class="govuk-table__cell orders-demo__party-cell">
                  <div class="govuk-radios govuk-radios--inline orders-demo__radios-inline">
                    <div class="govuk-radios__item">
                      <input class="govuk-radios__input" id="claimant-absent" name="claimantAttendance" type="radio" value="absent">
                      <label class="govuk-label govuk-radios__label" for="claimant-absent">
                        <span class="govuk-visually-hidden">Claimant</span>
                      </label>
                    </div>
                  </div>
                </td>
              </tr>
              {% set defendantList = defendants | default([]) %}
              {% if defendantList | length == 0 %}
                {% set defendantList = [defendantName | default('Jones'), 'Taylor', 'Patel'] %}
              {% endif %}
              {% for defendant in defendantList %}
                {% set idPrefix = 'defendant-' ~ loop.index %}
                <tr class="govuk-table__row">
                  <th scope="row" class="govuk-table__header">Defendant ({{ defendant }})</th>
                  <td class="govuk-table__cell orders-demo__party-cell">
                  <div class="govuk-radios govuk-radios--inline orders-demo__radios-inline">
                    <div class="govuk-radios__item">
                        <input class="govuk-radios__input" id="{{ idPrefix }}-lip" name="{{ idPrefix }}-attendance" type="radio" value="lip" checked>
                      <label class="govuk-label govuk-radios__label" for="{{ idPrefix }}-lip">
                        <span class="govuk-visually-hidden">Defendant</span>
                      </label>
                    </div>
                  </div>
                  </td>
                  <td class="govuk-table__cell orders-demo__party-cell">
                    <div class="govuk-radios govuk-radios--inline orders-demo__radios-inline">
                      <div class="govuk-radios__item">
                      <input class="govuk-radios__input" id="{{ idPrefix }}-counsel" name="{{ idPrefix }}-attendance" type="radio" value="counsel">
                        <label class="govuk-label govuk-radios__label" for="{{ idPrefix }}-counsel">
                          <span class="govuk-visually-hidden">Defendant</span>
                        </label>
                      </div>
                    </div>
                  </td>
                  <td class="govuk-table__cell orders-demo__party-cell">
                    <div class="govuk-radios govuk-radios--inline orders-demo__radios-inline">
                      <div class="govuk-radios__item">
                        <input class="govuk-radios__input" id="{{ idPrefix }}-solicitor" name="{{ idPrefix }}-attendance" type="radio" value="solicitor">
                        <label class="govuk-label govuk-radios__label" for="{{ idPrefix }}-solicitor">
                          <span class="govuk-visually-hidden">Defendant</span>
                        </label>
                      </div>
                    </div>
                  </td>
                  <td class="govuk-table__cell orders-demo__party-cell">
                    <div class="govuk-radios govuk-radios--inline orders-demo__radios-inline">
                      <div class="govuk-radios__item">
                      <input class="govuk-radios__input" id="{{ idPrefix }}-agent" name="{{ idPrefix }}-attendance" type="radio" value="solicitorAgent">
                        <label class="govuk-label govuk-radios__label" for="{{ idPrefix }}-agent">
                          <span class="govuk-visually-hidden">Defendant</span>
                        </label>
                      </div>
                    </div>
                  </td>
                  <td class="govuk-table__cell orders-demo__party-cell">
                    <div class="govuk-radios govuk-radios--inline orders-demo__radios-inline">
                      <div class="govuk-radios__item">
                      <input class="govuk-radios__input" id="{{ idPrefix }}-ho-rep" name="{{ idPrefix }}-attendance" type="radio" value="housingOfficerRep">
                        <label class="govuk-label govuk-radios__label" for="{{ idPrefix }}-ho-rep">
                          <span class="govuk-visually-hidden">Defendant</span>
                        </label>
                      </div>
                    </div>
                  </td>
                  <td class="govuk-table__cell orders-demo__party-cell">
                    <div class="govuk-radios govuk-radios--inline orders-demo__radios-inline">
                      <div class="govuk-radios__item">
                      <input class="govuk-radios__input" id="{{ idPrefix }}-absent" name="{{ idPrefix }}-attendance" type="radio" value="absent">
                        <label class="govuk-label govuk-radios__label" for="{{ idPrefix }}-absent">
                          <span class="govuk-visually-hidden">Defendant</span>
                        </label>
                      </div>
                    </div>
                  </td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>

        <div class="orders-demo__section orders-demo__order-section" data-order-type="outright">
          <div class="orders-demo__order-grid">
            <div class="orders-demo__order-chooser">
              <div class="govuk-radios govuk-radios--small" data-module="govuk-radios">
                <div class="govuk-radios__item">
                  <input class="govuk-radios__input" id="order-outright" name="orderType" type="radio" value="outright" checked>
                  <label class="govuk-label govuk-radios__label orders-demo__radio-label" for="order-outright">Select</label>
                </div>
              </div>
            </div>

            <div class="orders-demo__order-content">
              <div class="orders-demo__section-header orders-demo__order-header">
                <h2 class="govuk-heading-m govuk-!-margin-bottom-4">Outright possession order</h2>
              </div>

              <div class="orders-demo__order-body">
                {% set outrightDateHtml %}
                  <div class="orders-demo__date-inline orders-demo__date-inline--with-buttons" data-date-group="outrightBy">
                    {{ govukDateInput({
                      namePrefix: "outrightBy",
                      classes: "orders-demo__date-inline",
                      formGroup: { classes: "govuk-!-margin-bottom-0" },
                      items: [
                        { name: "day", classes: "govuk-input--width-2", autocomplete: "off" },
                        { name: "month", classes: "govuk-input--width-2", autocomplete: "off" },
                        { name: "year", classes: "govuk-input--width-4", autocomplete: "off" }
                      ]
                    }) }}
                    <div class="orders-demo__date-shortcuts" aria-hidden="true">
                      <button type="button" class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0 orders-demo__date-shortcut" data-offset="14">+14</button>
                      <button type="button" class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0 orders-demo__date-shortcut" data-offset="28">+28</button>
                      <button type="button" class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0 orders-demo__date-shortcut" data-offset="42">+42</button>
                    </div>
                  </div>
                {% endset %}

                <div class="orders-demo__inline-group">
                  {{ govukRadios({
                    classes: "govuk-radios--inline orders-demo__radios-slim",
                    name: "outrightTiming",
                    fieldset: {
                      legend: { text: "Outright possession timing", classes: "govuk-visually-hidden" }
                    },
                    items: [
                      { value: "forthwith", text: "Outright possession (forthwith)" },
                      {
                        value: "byDate",
                        text: "Outright possession by",
                        checked: true,
                        conditional: {
                          html: outrightDateHtml
                        }
                      }
                    ]
                  }) }}
                </div>

                {{ govukRadios({
                  classes: "orders-demo__radios-inline",
                  name: "grounds",
                  fieldset: {
                    legend: { text: "Grounds", classes: "govuk-fieldset__legend--s" }
                  },
                  items: [
                    { value: "discretionary", text: "Discretionary grounds" },
                    {
                      value: "mandatory",
                      text: "Mandatory grounds",
                      conditional: {
                        html: govukInput({
                          label: { text: "Specify mandatory grounds", classes: "govuk-visually-hidden" },
                          name: "mandatoryGroundsDetails",
                          classes: "govuk-input--width-20",
                          attributes: { placeholder: "Specify mandatory grounds" }
                        })
                      }
                    }
                  ]
                }) }}
              </div>
            </div>
          </div>
        </div>

        <div class="orders-demo__section orders-demo__order-section" data-order-type="suspended">
          <div class="orders-demo__order-grid">
            <div class="orders-demo__order-chooser">
              <div class="govuk-radios govuk-radios--small" data-module="govuk-radios">
                <div class="govuk-radios__item">
                  <input class="govuk-radios__input" id="order-suspended" name="orderType" type="radio" value="suspended">
                  <label class="govuk-label govuk-radios__label orders-demo__radio-label" for="order-suspended">Select</label>
                </div>
              </div>
            </div>

            <div class="orders-demo__order-content">
              <div class="orders-demo__section-header orders-demo__order-header">
                <h2 class="govuk-heading-m govuk-!-margin-bottom-4">Suspended possession order (tenancy)</h2>
              </div>

              <div class="orders-demo__order-body">
                <div class="orders-demo__suspended-rows">
                  <div class="orders-demo__suspended-row orders-demo__suspended-row--date">
                    <div class="orders-demo__checkbox-placeholder" aria-hidden="true"></div>
                    <span class="orders-demo__sentence-lead govuk-label">possession by</span>
                    <div class="orders-demo__sentence-body orders-demo__sentence-body--date">
                      {{ govukDateInput({
                        namePrefix: "suspendedBy",
                        classes: "orders-demo__date-inline",
                        formGroup: { classes: "govuk-!-margin-bottom-0" },
                        items: [
                          { name: "day", classes: "govuk-input--width-2", autocomplete: "off" },
                          { name: "month", classes: "govuk-input--width-2", autocomplete: "off" },
                          { name: "year", classes: "govuk-input--width-4", autocomplete: "off" }
                        ]
                      }) }}
                      <div class="orders-demo__date-shortcuts" aria-hidden="true">
                        <button type="button" class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0 orders-demo__date-shortcut" data-offset="14">+14</button>
                        <button type="button" class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0 orders-demo__date-shortcut" data-offset="28">+28</button>
                        <button type="button" class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0 orders-demo__date-shortcut" data-offset="42">+42</button>
                      </div>
                    </div>
                  </div>

                  <div class="orders-demo__suspended-row">
                    <div class="govuk-checkboxes govuk-checkboxes--small orders-demo__checkbox-single" data-module="govuk-checkboxes">
                      <div class="govuk-checkboxes__item">
                        <input class="govuk-checkboxes__input" id="arrearsCheckbox" name="arrearsCheckbox" type="checkbox" value="arrears" checked>
                        <label class="govuk-label govuk-checkboxes__label govuk-visually-hidden" for="arrearsCheckbox">Arrears checkbox</label>
                      </div>
                    </div>
                    <span class="orders-demo__sentence-lead govuk-label">suspended on payment of arrears of</span>
                    <div class="orders-demo__sentence-body">
                      {{ govukInput({
                        label: { text: "Arrears amount", classes: "govuk-visually-hidden" },
                        name: "arrearsAmount",
                        classes: "govuk-input--width-5 orders-demo__money-input",
                        prefix: { text: "£" },
                        attributes: { placeholder: "0.00" }
                      }) }}
                      <span class="orders-demo__sentence-label govuk-label">by</span>
                      {{ govukInput({
                        label: { text: "Arrears due by", classes: "govuk-visually-hidden" },
                        name: "arrearsDueBy",
                        classes: "govuk-input--width-10 orders-demo__date-input",
                        attributes: { placeholder: "DD/MM/YYYY" }
                      }) }}
                    </div>
                  </div>

                  <div class="orders-demo__suspended-row">
                    <div class="govuk-checkboxes govuk-checkboxes--small orders-demo__checkbox-single" data-module="govuk-checkboxes">
                      <div class="govuk-checkboxes__item">
                        <input class="govuk-checkboxes__input" id="initialPaymentCheckbox" name="initialPaymentCheckbox" type="checkbox" value="initialPayment">
                        <label class="govuk-label govuk-checkboxes__label govuk-visually-hidden" for="initialPaymentCheckbox">Initial payment checkbox</label>
                      </div>
                    </div>
                    <span class="orders-demo__sentence-lead govuk-label">an initial payment of</span>
                    <div class="orders-demo__sentence-body">
                      {{ govukInput({
                        label: { text: "Initial payment amount", classes: "govuk-visually-hidden" },
                        name: "initialPayment",
                        classes: "govuk-input--width-5 orders-demo__money-input",
                        prefix: { text: "£" },
                        attributes: { placeholder: "0.00" }
                      }) }}
                      <span class="orders-demo__sentence-label govuk-label">by</span>
                      {{ govukInput({
                        label: { text: "Initial payment due by", classes: "govuk-visually-hidden" },
                        name: "initialPaymentBy",
                        classes: "govuk-input--width-10 orders-demo__date-input",
                        attributes: { placeholder: "DD/MM/YYYY" }
                      }) }}
                    </div>
                  </div>

                  <div class="orders-demo__suspended-row">
                    <div class="govuk-checkboxes govuk-checkboxes--small orders-demo__checkbox-single" data-module="govuk-checkboxes">
                      <div class="govuk-checkboxes__item">
                        <input class="govuk-checkboxes__input" id="instalmentCheckbox" name="instalmentCheckbox" type="checkbox" value="instalments">
                        <label class="govuk-label govuk-checkboxes__label govuk-visually-hidden" for="instalmentCheckbox">Instalments checkbox</label>
                      </div>
                    </div>
                    <span class="orders-demo__sentence-lead govuk-label">instalments of</span>
                    <div class="orders-demo__sentence-body orders-demo__sentence-body--spread">
                      {{ govukInput({
                        label: { text: "Instalment amount", classes: "govuk-visually-hidden" },
                        name: "instalmentAmount",
                        classes: "govuk-input--width-5 orders-demo__money-input",
                        prefix: { text: "£" },
                        attributes: { placeholder: "0.00" }
                      }) }}
                      <span class="orders-demo__sentence-label govuk-label">per</span>
                      <div class="govuk-form-group govuk-!-margin-bottom-0 orders-demo__compact-select">
                        <label class="govuk-label govuk-visually-hidden" for="instalmentFrequency">Instalment frequency</label>
                        <select class="govuk-select" id="instalmentFrequency" name="instalmentFrequency">
                          <option value="weekly">weekly</option>
                          <option value="monthly" selected>monthly</option>
                          <option value="annually">annually</option>
                        </select>
                      </div>
                      <span class="orders-demo__sentence-label govuk-label">by</span>
                      {{ govukInput({
                        label: { text: "Instalments due by", classes: "govuk-visually-hidden" },
                        name: "instalmentDueBy",
                        classes: "govuk-input--width-10 orders-demo__date-input",
                        attributes: { placeholder: "DD/MM/YYYY" }
                      }) }}
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </form>
    </div>
  </main>
</div>
{% endblock %}

{% block footer %}
  {{ govukFooter({}) }}
{% endblock %}

{% block bodyEnd %}
  {{ super() }}
  <script>
    (() => {
      let orderSwitcherInitialised = false;

      const getShellRoot = () => {
        const shell = document.querySelector('hmcts-header-shell');
        return shell && (shell.shadowRoot || shell.querySelector('template[shadowrootmode="open"]')?.content);
      };

      const getNavList = () => {
        const root = getShellRoot();
        return root && root.querySelector('.hmcts-primary-navigation__list');
      };

      const trimNavToCreateCase = () => {
        const list = getNavList();
        if (!list) return false;

        const items = Array.from(list.querySelectorAll('.hmcts-primary-navigation__item'));
        const createCase = items.find(item => /Create case/i.test(item.textContent || ''));
        if (!createCase) return false;

        if (list.firstElementChild !== createCase || list.children.length !== 1) {
          list.innerHTML = '';
          list.appendChild(createCase);
        }
        return true;
      };

      const setupObserver = () => {
        const list = getNavList();
        if (!list) return false;

        trimNavToCreateCase();
        const observer = new MutationObserver(() => trimNavToCreateCase());
        observer.observe(list, { childList: true });
        return true;
      };

      const adjustPhaseBannerPadding = () => {
        const root = getShellRoot();
        const phaseText = root && root.querySelector('.govuk-phase-banner__text');
        if (!phaseText) return false;

        phaseText.style.paddingLeft = '0';
        return true;
      };

      const initOrderSwitcher = () => {
        if (orderSwitcherInitialised) return;

        const sections = Array.from(document.querySelectorAll('.orders-demo__order-section'));
        if (!sections.length) return;

        orderSwitcherInitialised = true;

        const offsetDate = offset => {
          const date = new Date();
          date.setDate(date.getDate() + offset);
          return {
            day: String(date.getDate()).padStart(2, '0'),
            month: String(date.getMonth() + 1).padStart(2, '0'),
            year: String(date.getFullYear())
          };
        };

        const setDefaultDate = (groupName, offsetDays = 14) => {
          const dayInput = document.querySelector(`input[name="${groupName}-day"]`);
          const monthInput = document.querySelector(`input[name="${groupName}-month"]`);
          const yearInput = document.querySelector(`input[name="${groupName}-year"]`);
          if (!dayInput || !monthInput || !yearInput) return;

          if (dayInput.value || monthInput.value || yearInput.value) return;

          const { day, month, year } = offsetDate(offsetDays);
          dayInput.value = day;
          monthInput.value = month;
          yearInput.value = year;
        };

        const initDateShortcuts = () => {
          const groups = Array.from(document.querySelectorAll('.orders-demo__date-inline--with-buttons'));
          groups.forEach(group => {
            const dayInput = group.querySelector('input[name$="-day"]');
            const monthInput = group.querySelector('input[name$="-month"]');
            const yearInput = group.querySelector('input[name$="-year"]');
            if (!dayInput || !monthInput || !yearInput) return;

            group.querySelectorAll('.orders-demo__date-shortcut').forEach(button => {
              const offset = Number(button.dataset.offset || 0);
              button.addEventListener('click', () => {
                const { day, month, year } = offsetDate(offset);
                dayInput.value = day;
                monthInput.value = month;
                yearInput.value = year;
              });
            });
          });
        };

        const initOrderClickTargets = () => {
          sections.forEach(section => {
            const radio = section.querySelector('input[name="orderType"]');
            if (!radio) return;

            section.addEventListener('click', event => {
              const target = event.target;
              if (!(target instanceof HTMLElement)) return;

              const isFormControl = target.closest('input, select, textarea, button');
              if (isFormControl && !(isFormControl instanceof HTMLInputElement && isFormControl.type === 'radio')) {
                return;
              }
              if (!radio.checked) {
                radio.checked = true;
                setActive(radio.value);
              }
            });
          });
        };

        const setActive = value => {
          sections.forEach(section => {
            const isActive = section.dataset.orderType === value;
            section.classList.toggle('orders-demo__order-section--active', isActive);
            section.classList.toggle('orders-demo__order-section--inactive', !isActive);
          });
        };

        const defaultValue = document.querySelector('input[name="orderType"]:checked')?.value
          || sections[0].dataset.orderType;

        sections.forEach(section => {
          const radio = section.querySelector('input[name="orderType"]');
          if (!radio) return;
          radio.addEventListener('change', () => setActive(radio.value));
        });

        setActive(defaultValue);
        setDefaultDate('outrightBy');
        setDefaultDate('suspendedBy');
        initDateShortcuts();
        initOrderClickTargets();
      };

      const start = () => {
        adjustPhaseBannerPadding();
        initOrderSwitcher();
        if (setupObserver()) return;

        let attempts = 0;
        const interval = setInterval(() => {
          const observerReady = setupObserver();
          adjustPhaseBannerPadding();
          initOrderSwitcher();
          if (observerReady || attempts >= 50) {
            clearInterval(interval);
          }
          attempts += 1;
        }, 200);
      };

      if (document.readyState === 'complete' || document.readyState === 'interactive') {
        start();
      } else {
        document.addEventListener('DOMContentLoaded', start);
      }
    })();
  </script>
