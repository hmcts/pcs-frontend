{
  "name": "pcs-frontend",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "docker:login:hmctsprod": "az acr login --name hmctsprod",
    "start:dev:pcs-local": "USE_VAULT=false NODE_CONFIG_ENV=pcs-local yarn start:dev",
    "start:dev:ssl": "./bin/generate-ssl-options.sh && NODE_ENV=development USE_SSL=true OIDC_REDIRECT_URI=https://localhost:3209/oauth2/callback yarn start:dev",
    "deps:up": "docker compose up -d",
    "deps:down": "docker compose down",
    "start:dev": "yarn deps:up && node --trace-deprecation --env-file-if-exists=.env -r ts-node/register -r tsconfig-paths/register src/main/bootstrap.ts",
    "start": "NODE_ENV=production node -r module-alias/register dist/main/bootstrap.js",
    "createIdamUser": "./bin/dev/createIdamUser.sh",
    "start:watch": "yarn deps:up && nodemon --config nodemon.json",
    "start:watch:pcs-local": "USE_VAULT=false NODE_CONFIG_ENV=pcs-local yarn start:watch",
    "docker:dev": "docker compose up",
    "docker:dev:ssl": "COMMAND='yarn start:dev:ssl' docker compose up --build",
    "lint": "stylelint **/*.scss -v -q && eslint . --ext .js,.ts && prettier --check .",
    "lint:fix": "prettier --write . .github && eslint --fix",
    "build": "yarn webpack --config webpack.config.js",
    "build:prod": "NODE_ENV=production yarn webpack --mode production --config webpack.config.js",
    "build:server": "tsc",
    "test": "npx if-env CI=true && exit 0 || yarn test:unit",
    "test:unit": "jest",
    "test:coverage": "jest --coverage",
    "test:routes": "jest -c jest.routes.config.ts",
    "test:a11y": "echo 'Accessibility tests implemented later in the pipeline'",
    "test:smoke": "yarn playwright install && E2E_SPEC= E2E_TEST_SCOPE= yarn playwright test --project chrome --grep \"@health\"; EXIT_CODE=$?; allure generate --clean; ts-node src/test/ui/config/clean-attachments.config.ts; exit $EXIT_CODE",
    "test:functional": "yarn playwright install && yarn playwright test --project chrome --grep \"${E2E_TEST_SCOPE:-@regression}\"; EXIT_CODE=$?; allure generate --clean; ts-node src/test/ui/config/clean-attachments.config.ts; exit $EXIT_CODE",
    "test:fullfunctional": "yarn playwright install && E2E_SPEC= E2E_TEST_SCOPE= yarn playwright test --project chrome; EXIT_CODE=$?; allure generate --clean; ts-node src/test/ui/config/clean-attachments.config.ts; exit $EXIT_CODE",
    "test:changed": "yarn playwright install && ts-node ./src/test/functional/helpers/runChangedTestHelper.ts; EXIT_CODE=$?; allure generate --clean; ts-node src/test/ui/config/clean-attachments.config.ts; exit $EXIT_CODE",
    "test:crossbrowser": "bash src/test/ui/sauceCrossbrowser/sauce-run.sh",
    "test:sauce:nightly": "SAUCE_TUNNEL_NAME=\"${SAUCE_TUNNEL_NAME:-reformtunnel}\" SAUCE_GREP=\"${SAUCE_GREP:-@crossbrowser}\" yarn exec saucectl run -c .sauce/config-sauce-nightly.yml --select-suite \"${SAUCE_SUITE_NAME:-pcs-frontend-mac13-chrome}\"",
    "test:E2e": "yarn playwright install && yarn playwright install msedge && yarn playwright test --project \"${PLAYWRIGHT_PROJECT:-chrome}\"; EXIT_CODE=$?; allure generate --clean; ts-node src/test/ui/config/clean-attachments.config.ts; exit $EXIT_CODE",
    "test:pact": "jest -c jest.pact.config.ts --runInBand",
    "pact:publish": "ts-node src/test/contract/publish/*.ts",
    "test:pact:run-and-publish": "yarn test:pact && yarn pact:publish",
    "test:can-i-deploy:consumer": "pact-broker can-i-deploy --pacticipant 'pcs_frontend' --version $(git rev-parse --short=7 HEAD) --broker-base-url https://pact-broker.platform.hmcts.net",
    "test:openAllureReport": "yarn allure open allure-report",
    "fortifyScan": "./src/test/java/gradlew -p src/test/java fortifyScan",
    "prepare": "husky",
    "lint-staged": "lint-staged"
  },
  "_moduleAliases": {
    "@modules": "dist/main/modules",
    "@services": "dist/main/services",
    "@utils": "dist/main/utils",
    "@routes": "dist/main/routes",
    "@middleware": "dist/main/middleware",
    "@steps": "dist/main/steps",
    "@app": "dist/main/app",
    "@router": "dist/main/router"
  },
