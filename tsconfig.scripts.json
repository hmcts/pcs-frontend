{
  "compilerOptions": {
    "rootDir": ".",
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noUnusedLocals": true
  },
  "include": [
    "scripts/**/*.ts",
    "playwright.sauce.config.ts",
    "playwright.saucegrid.config.ts",
    "src/test/ui/data/api-data/s2SToken.api.data.ts",
    "src/test/ui/data/api-data/accessToken.api.data.ts",
    "src/test/ui/data/user-data/permanent.user.data.ts"
  ],
  "exclude": []
}
