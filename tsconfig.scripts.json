{
  "compilerOptions": {
    "rootDir": ".",
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noUnusedLocals": true
  },
  "include": [
    "scripts/**/*.ts",
    "playwright.sauce.config.ts",
    "src/test/ui/crossbrowser/**/*.ts"
  ],
  "exclude": []
}
